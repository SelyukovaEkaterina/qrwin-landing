    function applyPreset(i: number) {
        const p = PRESETS[i];
        if (p.gradient) {
            state.gradient = true;
            state.grad1 = p.grad1!;
            state.grad2 = p.grad2!;
            state.gradType = p.gradType!;
            ($('input-gradient') as HTMLInputElement).checked = true;
            ($('input-grad1') as HTMLInputElement).value = p.grad1!;
            ($('input-grad2') as HTMLInputElement).value = p.grad2!;
            ($('input-grad-type') as HTMLSelectElement).value = p.gradType!;
            $('gradient-controls').classList.remove('hidden');
            $('gradient-controls').classList.add('grid');
        } else {
            state.gradient = false;
            state.fg = p.fg!;
            ($('input-gradient') as HTMLInputElement).checked = false;
            ($('input-fg') as HTMLInputElement).value = p.fg!;
            ($('input-fg-text') as HTMLInputElement).value = p.fg!;
            $('gradient-controls').classList.add('hidden');
            $('gradient-controls').classList.remove('grid');
        }
        state.bg = p.bg!;
        state.bgTransparent = false;
        ($('input-bg') as HTMLInputElement).value = p.bg!;
        ($('input-bg-text') as HTMLInputElement).value = p.bg!;
        scheduleUpdate();
    }

    // ── Color inputs ──────────────────────────────────────
    function syncColorPair(colorEl: HTMLInputElement, textEl: HTMLInputElement, key: 'fg' | 'bg') {
        colorEl.addEventListener('input', () => {
            textEl.value = colorEl.value;
            state[key] = colorEl.value;
            if (key === 'bg') state.bgTransparent = false;
            scheduleUpdate();
        });
        textEl.addEventListener('change', () => {
            const v = textEl.value.trim();
            if (/^#[0-9a-fA-F]{6}$/.test(v)) {
                colorEl.value = v;
                state[key] = v;
                if (key === 'bg') state.bgTransparent = false;
                scheduleUpdate();
            } else {
                textEl.value = state[key];
            }
        });
    }
