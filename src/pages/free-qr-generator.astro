        const btn = document.createElement('button');
        btn.className = 'preset-btn' + (i === 0 ? ' active-preset' : '');
        btn.dataset.idx = String(i);
        btn.title = p.name;
        if (p.gradient) {
            const angle = p.gradType === 'linear-tb' ? '180deg' : p.gradType === 'linear-lr' ? '90deg' : p.gradType === 'linear-diag' ? '135deg' : 'circle';
            if (p.gradType === 'radial') {
                btn.style.background = `radial-gradient(circle, ${p.grad1}, ${p.grad2})`;
            } else {
                btn.style.background = `linear-gradient(${angle}, ${p.grad1}, ${p.grad2})`;
            }
        } else {
            btn.style.background = p.fg!;
        }
        btn.addEventListener('click', () => {
            document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('active-preset'));
            btn.classList.add('active-preset');
            applyPreset(i);
