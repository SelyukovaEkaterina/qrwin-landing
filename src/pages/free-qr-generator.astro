        { name: 'Круг', emoji: '🎯' },
    ];

    function emojiToImage(emoji: string): HTMLImageElement {
        const size = 200;
        const c = document.createElement('canvas');
        c.width = size;
        c.height = size;
        const ectx = c.getContext('2d')!;
        ectx.clearRect(0, 0, size, size);
        ectx.font = `${size * 0.7}px "Apple Color Emoji","Segoe UI Emoji","Noto Color Emoji",sans-serif`;
        ectx.textAlign = 'center';
        ectx.textBaseline = 'middle';
        ectx.fillText(emoji, size / 2, size / 2);
        const img = new Image();
        img.src = c.toDataURL();
        return img;
    }

    function loadLogoImage(p: { emoji?: string; src?: string }, cb: (img: HTMLImageElement) => void) {
        if (p.src) {
            const img = new Image();
            img.src = p.src;
            img.onload = () => cb(img);
        } else if (p.emoji) {
            const img = emojiToImage(p.emoji);
            if (img.complete) cb(img);
            else img.onload = () => cb(img);
        }
    }

    function renderLogoPresets() {
        const container = $('logo-presets');
        LOGO_PRESETS.forEach((p, i) => {
            const btn = document.createElement('button');
            btn.className = 'logo-preset-btn';
            btn.title = p.name;
            if (p.emoji) {
                btn.textContent = p.emoji;
                Object.assign(btn.style, {
                    aspectRatio: '1',
                    borderRadius: '0.625rem',
                    border: '2px solid #e2e8f0',
                    cursor: 'pointer',
                    fontSize: '1.4rem',
                    lineHeight: '1',
                    background: '#f8fafc',
                    transition: 'all 0.15s',
                });
            } else {
                Object.assign(btn.style, {
                    aspectRatio: '1',
                    borderRadius: '0.625rem',
                    border: i === 0 ? '2px solid #4F46E5' : '2px solid #e2e8f0',
                    cursor: 'pointer',
                    backgroundImage: `url(${p.src})`,
                    backgroundSize: 'contain',
                    backgroundPosition: 'center',
                    backgroundRepeat: 'no-repeat',
                    backgroundColor: '#f8fafc',
                    transition: 'all 0.15s',
                });
            }
            btn.addEventListener('mouseenter', () => { if (btn.style.borderColor !== '#4F46E5') btn.style.borderColor = '#4F46E5'; });
            btn.addEventListener('mouseleave', () => { if (btn.style.borderColor !== 'rgb(79, 70, 229)') btn.style.borderColor = '#e2e8f0'; });
            btn.addEventListener('click', () => {
                loadLogoImage(p, (img) => {
                    state.logoImage = img;
                    document.querySelectorAll('.logo-preset-btn').forEach(b => ((b as HTMLElement).style.borderColor = '#e2e8f0'));
                    btn.style.borderColor = '#4F46E5';
                    scheduleUpdate();
                });
            });
            container.appendChild(btn);
        });
    }
    renderLogoPresets();

    const defaultLogo = new Image();
    defaultLogo.src = '/logo.svg';
    defaultLogo.onload = () => {
        state.logoImage = defaultLogo;
        generate();
    };

    // ── Tabs ──────────────────────────────────────────────
    function switchTab(type: QrType) {
        state.type = type;
        tabs.forEach(t => t.classList.toggle('active-tab', t.dataset.type === type));
        forms.forEach(f => f.classList.add('hidden'));
        $(`form-${type}`)?.classList.remove('hidden');
        saveToHash();
    }
    tabs.forEach(tab => {
        tab.addEventListener('click', () => switchTab(tab.dataset.type as QrType));
    });

    // ── Style buttons ─────────────────────────────────────
    styleBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            state.dotStyle = btn.dataset.style as DotStyle;
            styleBtns.forEach(b => b.classList.toggle('active-style', b.dataset.style === state.dotStyle));
            scheduleUpdate();
        });
    });

    eyeBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            state.eyeStyle = btn.dataset.eye as EyeStyle;
            eyeBtns.forEach(b => b.classList.toggle('active-eye', b.dataset.eye === state.eyeStyle));
            scheduleUpdate();
        });
    });

    // ── Presets ───────────────────────────────────────────
