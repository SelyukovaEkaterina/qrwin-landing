<script>
    import QRCode from 'qrcode';
    import jsQR from 'jsqr';

    type QrType = 'url' | 'wifi' | 'text' | 'email' | 'phone' | 'vcard' | 'sms';
    type DotStyle = 'classic' | 'rounded';
    type EyeStyle = 'square' | 'rounded' | 'circle' | 'leaf' | 'dot';
    type GradType = 'linear-tb' | 'linear-lr' | 'linear-diag' | 'radial';

    const state = {
        type: 'url' as QrType,
        dotStyle: 'classic' as DotStyle,
        eyeStyle: 'square' as EyeStyle,
        fg: '#1e293b',
        bg: '#ffffff',
        bgTransparent: false,
        gradient: false,
        grad1: '#4f46e5',
        grad2: '#a855f7',
        gradType: 'linear-tb' as GradType,
        eyeCustom: false,
        eyeColor: '#4f46e5',
        logoImage: null as HTMLImageElement | null,
        logoSize: 22,
        logoFill: true,
        photoImage: null as HTMLImageElement | null,
        frame: false,
        frameText: 'СКАНИРУЙ МЕНЯ',
        frameStyle: 'bottom' as 'bottom' | 'rounded' | 'ribbon',
        scatter: false,
        scatterDensity: 3,
        scatterShape: 'square' as 'square' | 'circle' | 'star' | 'diamond' | 'hexagon' | 'heart' | 'cross' | 'octagon' | 'triangle',
        ecc: 'H' as 'L' | 'M' | 'Q' | 'H',
        margin: 2,
    };

    // ── Presets ───────────────────────────────────────────
    const PRESETS = [
        { name: 'Классика',       fg: '#1e293b', bg: '#ffffff', gradient: false },
        { name: 'Индиго',          fg: '#4f46e5', bg: '#ffffff', gradient: false },
        { name: 'Океан',           fg: '#0284c7', bg: '#f0f9ff', gradient: false },
        { name: 'Изумруд',         fg: '#059669', bg: '#ffffff', gradient: false },
        { name: 'Закат',           gradient: true, grad1: '#f97316', grad2: '#dc2626', gradType: 'linear-diag' as GradType, bg: '#ffffff' },
        { name: 'Фиолет',          gradient: true, grad1: '#4f46e5', grad2: '#a855f7', gradType: 'linear-tb' as GradType, bg: '#ffffff' },
        { name: 'Неон',            gradient: true, grad1: '#06b6d4', grad2: '#8b5cf6', gradType: 'linear-lr' as GradType, bg: '#0f172a' },
        { name: 'Розовый',         gradient: true, grad1: '#ec4899', grad2: '#f43f5e', gradType: 'radial' as GradType, bg: '#ffffff' },
        { name: 'Полночь',         fg: '#f8fafc', bg: '#0f172a', gradient: false },
        { name: 'Золото',          gradient: true, grad1: '#ca8a04', grad2: '#fbbf24', gradType: 'linear-tb' as GradType, bg: '#1c1917' },
    ];

    // ── DOM refs ──────────────────────────────────────────
    const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T;

    const tabs = document.querySelectorAll<HTMLButtonElement>('.qr-tab');
    const forms = document.querySelectorAll<HTMLDivElement>('.qr-form');
    const canvas = $('qr-canvas') as HTMLCanvasElement;
    const placeholder = $('qr-placeholder');
    const previewWrapper = $('qr-preview-wrapper');
    const btnGenerate = $('btn-generate') as HTMLButtonElement;
    const btnGenerateMobile = $('btn-generate-mobile') as HTMLButtonElement;
    const btnDownloadPng = $('btn-download-png') as HTMLButtonElement;
    const btnDownloadJpg = $('btn-download-jpg') as HTMLButtonElement;
    const styleBtns = document.querySelectorAll<HTMLButtonElement>('.style-btn');
    const eyeBtns = document.querySelectorAll<HTMLButtonElement>('.eye-btn');
    const styleCanvases = document.querySelectorAll<HTMLCanvasElement>('.style-canvas');
    const eyeCanvases = document.querySelectorAll<HTMLCanvasElement>('.eye-canvas');

    let qrCanvasDataUrl: string | null = null;
    let lastPayload: string | null = null;
    let autoUpdate = false;

    const LOGO_PRESETS: { name: string; emoji?: string; src?: string }[] = [
        { name: 'QrStars', src: '/logo.svg' },
        { name: 'Клиника', emoji: '🏥' },
        { name: 'Стоматология', emoji: '🦷' },
        { name: 'Аптека', emoji: '💊' },
        { name: 'Ветеринар', emoji: '🐾' },
