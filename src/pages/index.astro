---
import Layout from '../layouts/Layout.astro';
import PreRegistrationForm from '../components/PreRegistrationForm.astro';

const proPrice = '990 ₽';
const proPlusPrice = '2 500 ₽';
const kitPrice = '1 999 ₽';
---

<Layout title="QrStars — умные QR-коды для бизнеса" description="Динамические QR-коды для отзывов на Яндекс Картах и 2GIS, меню, WiFi и визиток. Создайте бесплатно за 30 секунд — попробуйте QrStars.">
    <!-- Главный экран -->
    <section class="pt-32 pb-20 lg:pt-40 lg:pb-28 overflow-hidden bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <div class="inline-block bg-primary/10 text-primary font-semibold px-4 py-1.5 rounded-full text-sm mb-6 border border-primary/20">
                Продвинутая платформа для QR-кодов, которые уже работают в вашем бизнесе
            </div>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight mb-6 max-w-4xl mx-auto">
                Один QR-код для умных отзывов,<br class="hidden md:block" />
                <span class="bg-gradient-to-r from-primary to-purple-500 gradient-text">электронного меню и роста продаж</span>
            </h1>
            <p class="text-lg md:text-xl text-slate-600 mb-10 max-w-2xl mx-auto leading-relaxed">
                QrStars помогает кафе, салонам и клиникам получать отзывы 5★, обновлять электронное меню без перепечатки, передавать файлы и мотивировать клиентов на чаевые или повторную запись. Подключите свой напечатанный QR-код в тарифе PRO или закажите готовый набор со стендом, наклейками и подпиской в подарок.
            </p>
            
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="#buy" class="bg-primary text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-indigo-700 transition shadow-lg shadow-indigo-500/30">
                    Выбрать тариф
                </a>
                <a href="#features" class="bg-white text-slate-700 border border-slate-200 px-8 py-4 rounded-xl font-bold text-lg hover:bg-slate-50 transition shadow-sm">
                    Возможности PRO
                </a>
            </div>

            <div class="mt-8 flex flex-wrap justify-center gap-3 text-sm text-slate-600">
                <span class="inline-flex items-center gap-2 bg-slate-50 border border-slate-200 px-4 py-2 rounded-full"><i class="fa-solid fa-qrcode text-primary"></i> PRO для своих QR — от {proPrice}/мес</span>
                <span class="inline-flex items-center gap-2 bg-slate-50 border border-slate-200 px-4 py-2 rounded-full"><i class="fa-solid fa-tablet-screen-button text-primary"></i> Готовый набор — {kitPrice}</span>
                <span class="inline-flex items-center gap-2 bg-slate-50 border border-slate-200 px-4 py-2 rounded-full"><i class="fa-solid fa-gift text-primary"></i> 3 месяца PRO в подарок к набору</span>
            </div>
        </div>
    </section>

    <!-- Все возможности -->
    <section id="features" class="py-20 bg-slate-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16">
                <h2 class="text-3xl font-bold mb-4">Полный цикл работы с клиентом — в одном QR-коде</h2>
                <p class="text-slate-600 max-w-2xl mx-auto">QrStars объединяет сбор отзывов, электронное меню, QR-файлы, визитки сотрудников и аналитику. Без скачивания приложений и сложных настроек — подключите свои QR-коды или активируйте готовую табличку.</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <!-- Умные отзывы -->
                <a href="/smart-reviews.html" class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition feature-card group block">
                    <div class="w-14 h-14 bg-amber-100 rounded-xl flex items-center justify-center mb-6">
                        <i class="fa-solid fa-star text-2xl text-amber-500 group-hover:scale-110 transition"></i>
                    </div>
                    <h3 class="font-bold text-xl mb-3">Умные отзывы</h3>
                    <p class="text-slate-600 text-sm leading-relaxed">Автоматически направляйте довольных клиентов на Яндекс и 2GIS — рейтинг растёт. Негатив уходит лично вам в Telegram, минуя публичные страницы. Используйте готовую табличку или печатайте материалы сами.</p>
                    <span class="inline-block mt-4 text-primary text-sm font-semibold group-hover:underline">Подробнее об отзывах →</span>
                </a>

                <!-- QR-меню -->
                <a href="/qr-menu.html" class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition feature-card group block">
                    <div class="w-14 h-14 bg-lime-100 rounded-xl flex items-center justify-center mb-6">
                        <i class="fa-solid fa-utensils text-2xl text-lime-600 group-hover:scale-110 transition"></i>
                    </div>
                    <h3 class="font-bold text-xl mb-3">QR-меню <span class="text-xs font-semibold text-amber-700 bg-amber-100 px-2 py-0.5 rounded-full ml-1 align-middle">PRO</span></h3>
                    <p class="text-slate-600 text-sm leading-relaxed">Гибкий конструктор меню: категории, фотографии, кнопки и актуальные цены. Скрывайте закончившиеся позиции в личном кабинете — физический QR-код на столиках остаётся тем же.</p>
                    <span class="inline-block mt-4 text-primary text-sm font-semibold group-hover:underline">Подробнее о меню →</span>
                </a>

                <!-- QR-файлы -->
                <a href="/file-sharing.html" class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition feature-card group block">
                    <div class="w-14 h-14 bg-orange-100 rounded-xl flex items-center justify-center mb-6">
                        <i class="fa-solid fa-file-arrow-down text-2xl text-orange-500 group-hover:scale-110 transition"></i>
                    </div>
                    <h3 class="font-bold text-xl mb-3">QR-файлы <span class="text-xs font-semibold text-amber-700 bg-amber-100 px-2 py-0.5 rounded-full ml-1 align-middle">PRO</span></h3>
                    <p class="text-slate-600 text-sm leading-relaxed">Меню в PDF, прайс-листы, каталоги и инструкции обновляются за минуту. Клиент получает файл в телефоне, а вы меняете его содержимое без перепечатки табличек.</p>
                    <span class="inline-block mt-4 text-primary text-sm font-semibold group-hover:underline">Подробнее про QR-файлы →</span>
                </a>

                <!-- Визитки сотрудников -->
                <a href="/qr-business-cards.html" class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition feature-card group block">
                    <div class="w-14 h-14 bg-blue-100 rounded-xl flex items-center justify-center mb-6">
                        <i class="fa-solid fa-id-badge text-2xl text-blue-500 group-hover:scale-110 transition"></i>
                    </div>
                    <h3 class="font-bold text-xl mb-3">Визитки сотрудников <span class="text-xs font-semibold text-amber-700 bg-amber-100 px-2 py-0.5 rounded-full ml-1 align-middle">PRO</span></h3>
                    <p class="text-slate-600 text-sm leading-relaxed">Электронные визитки команды: клиент сохраняет контакты в один клик и оставляет чаевые напрямую. Без комиссий с нашей стороны — просто удобная кнопка и статистика.</p>
                    <span class="inline-block mt-4 text-primary text-sm font-semibold group-hover:underline">Подробнее о визитках →</span>
                </a>

                <!-- Динамическая ссылка -->
                <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition feature-card group">
                    <div class="w-14 h-14 bg-green-100 rounded-xl flex items-center justify-center mb-6">
                        <i class="fa-solid fa-link text-2xl text-green-500 group-hover:scale-110 transition"></i>
                    </div>
                    <h3 class="font-bold text-xl mb-3">Динамическая ссылка</h3>
                    <p class="text-slate-600 text-sm leading-relaxed">Материалы уже напечатаны, а ссылку нужно изменить? Меняйте целевой адрес в панели управления без замены наклеек и табличек.</p>
                </div>

                <!-- Подробная статистика -->
                <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition feature-card group">
                    <div class="w-14 h-14 bg-purple-100 rounded-xl flex items-center justify-center mb-6">
                        <i class="fa-solid fa-chart-pie text-2xl text-purple-500 group-hover:scale-110 transition"></i>
                    </div>
                    <h3 class="font-bold text-xl mb-3">Подробная статистика</h3>
                    <p class="text-slate-600 text-sm leading-relaxed">Отслеживайте каждое сканирование. Узнавайте, какие столики, мастера или филиалы приносят больше переходов и отзывов. Наглядная сводка конверсии в реальном времени.</p>
                </div>

                <!-- Конструктор QR-кодов -->
                <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition feature-card group">
                    <div class="w-14 h-14 bg-pink-100 rounded-xl flex items-center justify-center mb-6">
                        <i class="fa-solid fa-qrcode text-2xl text-pink-500 group-hover:scale-110 transition"></i>
                    </div>
                    <h3 class="font-bold text-xl mb-3">Конструктор QR-кодов</h3>
                    <p class="text-slate-600 text-sm leading-relaxed">Создавайте QR-коды для меню, сбора отзывов и визиток с вашим логотипом, фирменными цветами и понятным сценарием.</p>
                </div>

                <!-- Макеты для печати -->
                <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition feature-card group">
                    <div class="w-14 h-14 bg-teal-100 rounded-xl flex items-center justify-center mb-6">
                        <i class="fa-solid fa-print text-2xl text-teal-500 group-hover:scale-110 transition"></i>
                    </div>
                    <h3 class="font-bold text-xl mb-3">Макеты для печати</h3>
                    <p class="text-slate-600 text-sm leading-relaxed">Предпочитаете свои материалы? Сгенерируйте макет тейбл-тента прямо в браузере, скачайте PDF и распечатайте в любой типографии.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Отраслевые решения -->
    <section id="solutions" class="py-20 bg-white border-y border-slate-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col md:flex-row justify-between items-end mb-12">
                <div class="max-w-2xl">
                    <h2 class="text-3xl font-bold mb-4">Готовые сценарии для вашей отрасли</h2>
                    <p class="text-slate-600">Проверенные решения для заведений, салонов, клиник и сервисов — с ощутимыми результатами по отзывам, продажам и лояльности клиентов.</p>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                <!-- Рестораны -->
                <div class="block group relative rounded-2xl overflow-hidden aspect-[4/5] bg-slate-900 cursor-pointer">
                    <img src="https://images.unsplash.com/photo-1554118811-1e0d58224f24?auto=format&fit=crop&q=80&w=800" alt="Кофейни и рестораны" class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-40 transition duration-500 group-hover:scale-105">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
                    <div class="absolute bottom-0 left-0 p-6">
                        <div class="bg-white/20 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-semibold text-white inline-block mb-3">Рестораны</div>
                        <h3 class="text-xl font-bold text-white mb-2">Кофейни и рестораны</h3>
                        <p class="text-slate-300 text-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300 translate-y-4 group-hover:translate-y-0">Отзывы на столиках, электронное меню и чаевые официантам ➔</p>
                    </div>
                </div>

                <!-- Красота -->
                <div class="block group relative rounded-2xl overflow-hidden aspect-[4/5] bg-slate-900 cursor-pointer">
                    <img src="https://images.unsplash.com/photo-1560066984-138dadb4c035?auto=format&fit=crop&q=80&w=800" alt="Салоны красоты" class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-40 transition duration-500 group-hover:scale-105">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
                    <div class="absolute bottom-0 left-0 p-6">
                        <div class="bg-white/20 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-semibold text-white inline-block mb-3">Красота</div>
                        <h3 class="text-xl font-bold text-white mb-2">Салоны красоты и барбершопы</h3>
                        <p class="text-slate-300 text-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300 translate-y-4 group-hover:translate-y-0">Визитки мастеров, чаевые и отзывы на зеркалах ➔</p>
                    </div>
                </div>

                <!-- Медицина -->
                <div class="block group relative rounded-2xl overflow-hidden aspect-[4/5] bg-slate-900 cursor-pointer">
                    <img src="https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?auto=format&fit=crop&q=80&w=800" alt="Клиники" class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-40 transition duration-500 group-hover:scale-105">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
                    <div class="absolute bottom-0 left-0 p-6">
                        <div class="bg-white/20 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-semibold text-white inline-block mb-3">Медицина</div>
                        <h3 class="text-xl font-bold text-white mb-2">Медицинские центры</h3>
                        <p class="text-slate-300 text-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300 translate-y-4 group-hover:translate-y-0">Приватный сбор обратной связи для руководства и отзывы о врачах ➔</p>
                    </div>
                </div>

                <!-- Авто -->
                <div class="block group relative rounded-2xl overflow-hidden aspect-[4/5] bg-slate-900 cursor-pointer">
                    <img src="https://images.unsplash.com/photo-1619642751034-765dfdf7c58e?auto=format&fit=crop&q=80&w=800" alt="Автосервисы" class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-40 transition duration-500 group-hover:scale-105">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
                    <div class="absolute bottom-0 left-0 p-6">
                        <div class="bg-white/20 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-semibold text-white inline-block mb-3">Авто</div>
                        <h3 class="text-xl font-bold text-white mb-2">Автосервисы и детейлинг</h3>
                        <p class="text-slate-300 text-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300 translate-y-4 group-hover:translate-y-0">Перехват негатива и рост рейтинга на картах ➔</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Тарифы / Продажа -->
    <section id="buy" class="py-20 bg-slate-900 text-white relative overflow-hidden">
        <!-- Декор -->
        <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 bg-primary rounded-full mix-blend-screen filter blur-[100px] opacity-30"></div>
        <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-96 h-96 bg-purple-600 rounded-full mix-blend-screen filter blur-[100px] opacity-30"></div>
        
        <div class="max-w-7xl mx-auto px-4 relative z-10">
            <div class="text-center mb-16 max-w-4xl mx-auto">
                <h2 class="text-3xl lg:text-4xl font-bold mb-4">Выберите формат: подписка или готовый набор</h2>
                <p class="text-slate-400 text-lg">Ценность QrStars — в дистанционном обновлении, гибком управлении и подробной статистике. После окончания подписки PRO ваши материалы продолжат работать в базовом режиме, но инструменты редактирования будут приостановлены.</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- PRO -->
                <div class="bg-slate-800/50 backdrop-blur border border-slate-700 p-8 rounded-3xl flex flex-col">
                    <div class="mb-6">
                        <div class="inline-block bg-primary/20 text-indigo-300 font-semibold px-3 py-1 rounded-full text-xs mb-4 border border-indigo-500/30">Подписка PRO</div>
                        <h3 class="text-2xl font-bold text-white mb-2">Тариф PRO</h3>
                        <div class="text-4xl font-bold text-white mb-2">{proPrice} <span class="text-lg text-slate-400 font-normal">/ месяц</span></div>
                        <p class="text-slate-400 text-sm">До 7 QR-кодов. Отличный старт для небольшого бизнеса со своими напечатанными материалами.</p>
                    </div>
                    
                    <ul class="space-y-4 mb-8 flex-1">
                        <li class="flex items-start gap-3"><i class="fa-solid fa-check text-primary mt-1"></i> <span class="font-medium">Управление до 7 QR-кодами</span></li>
                        <li class="flex items-start gap-3"><i class="fa-solid fa-check text-primary mt-1"></i> <span>Ротация отзывов на картах</span></li>
                        <li class="flex items-start gap-3"><i class="fa-solid fa-check text-primary mt-1"></i> <span>Электронное меню и прайсы</span></li>
                        <li class="flex items-start gap-3"><i class="fa-solid fa-check text-primary mt-1"></i> <span>QR-файлы и инструкции</span></li>
                        <li class="flex items-start gap-3"><i class="fa-solid fa-check text-primary mt-1"></i> <span>Визитки сотрудников и чаевые</span></li>
                        <li class="flex items-start gap-3"><i class="fa-solid fa-check text-primary mt-1"></i> <span>Базовая статистика сканирований</span></li>
                    </ul>
                    
                    <a href="#" class="block w-full text-center bg-slate-700 text-white px-6 py-3 rounded-xl font-bold hover:bg-slate-600 transition">
                        Выбрать PRO
                    </a>
                </div>

                <!-- PRO+ -->
                <div class="bg-gradient-to-br from-indigo-900 to-slate-900 border border-primary/50 p-8 rounded-3xl flex flex-col relative transform md:-translate-y-4 shadow-2xl shadow-primary/20">
                    <div class="absolute top-0 right-0 bg-primary text-white text-xs font-bold px-3 py-1 rounded-bl-xl rounded-tr-3xl">Выбор профи</div>
                    <div class="mb-6">
                        <div class="inline-block bg-primary/20 text-indigo-300 font-semibold px-3 py-1 rounded-full text-xs mb-4 border border-indigo-500/30">Подписка PRO+</div>
                        <h3 class="text-2xl font-bold text-white mb-2">Тариф PRO+</h3>
                        <div class="text-4xl font-bold text-white mb-2">{proPlusPrice} <span class="text-lg text-slate-400 font-normal">/ месяц</span></div>
                        <p class="text-slate-300 text-sm">До 25 QR-кодов. Идеально для средних заведений, сетей и клиник с множеством точек контакта.</p>
                    </div>
                    
                    <ul class="space-y-4 mb-8 flex-1">
                        <li class="flex items-start gap-3"><i class="fa-solid fa-check text-primary mt-1"></i> <span class="font-semibold">Управление до 25 QR-кодами</span></li>
                        <li class="flex items-start gap-3"><i class="fa-solid fa-check text-primary mt-1"></i> <span>Все возможности тарифа PRO</span></li>
                        <li class="flex items-start gap-3"><i class="fa-solid fa-check text-primary mt-1"></i> <span>Подробная статистика и выгрузка</span></li>
                        <li class="flex items-start gap-3"><i class="fa-solid fa-check text-primary mt-1"></i> <span>Приоритетная поддержка</span></li>
                    </ul>
                    
                    <a href="#" class="block w-full text-center bg-primary text-white px-6 py-3 rounded-xl font-bold hover:bg-indigo-700 transition">
                        Выбрать PRO+
                    </a>
                </div>

                <!-- Готовый набор -->
                <div class="bg-slate-800/50 backdrop-blur border border-slate-700 p-8 rounded-3xl flex flex-col">
                    <div class="mb-6">
                        <div class="inline-block bg-primary/20 text-indigo-300 font-semibold px-3 py-1 rounded-full text-xs mb-4 border border-indigo-500/30">Оборудование + PRO</div>
                        <h3 class="text-2xl font-bold text-white mb-2">Готовый набор</h3>
                        <div class="text-4xl font-bold text-white mb-2">{kitPrice}</div>
                        <p class="text-slate-400 text-sm">Стенд, наклейки и 3 месяца PRO в подарок. Готовое решение для одной точки.</p>
                    </div>
                    
                    <ul class="space-y-4 mb-8 flex-1">
                        <li class="flex items-start gap-3"><i class="fa-solid fa-check text-primary mt-1"></i> <span>Акриловый стенд с чипом NFC</span></li>
                        <li class="flex items-start gap-3"><i class="fa-solid fa-check text-primary mt-1"></i> <span>5 долговечных QR-наклеек</span></li>
                        <li class="flex items-start gap-3"><i class="fa-solid fa-check text-primary mt-1"></i> <span class="font-semibold">3 месяца PRO бесплатно</span></li>
                        <li class="flex items-start gap-3"><i class="fa-solid fa-check text-primary mt-1"></i> <span>Мгновенные уведомления руководителю</span></li>
                    </ul>
                    
                    <div class="flex flex-col gap-3 mt-auto">
                        <a href="https://ozon.ru" target="_blank" rel="noreferrer" class="block w-full text-center bg-ozon text-white px-6 py-3 rounded-xl font-bold hover:bg-blue-700 transition flex items-center justify-center gap-2">
                            Купить на Ozon <i class="fa-solid fa-cart-shopping"></i>
                        </a>
