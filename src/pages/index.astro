                <td class="p-4 text-center text-green-400"><i class="fa-solid fa-check"></i> Любой внешний сервис</td>
              </tr>
              <tr>
                <td class="p-4 text-slate-300">Аналитика</td>
                <td class="p-4 text-center"><i class="fa-solid fa-xmark text-red-500"></i></td>
                <td class="p-4 text-center text-green-400"><i class="fa-solid fa-check"></i> Сканирования по QR и времени</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────── FAQ ───────────── -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="inline-block bg-primary/10 text-primary font-semibold px-4 py-1.5 rounded-full text-sm mb-4 border border-primary/20">Вопросы и ответы</div>
        <h2 class="text-3xl font-bold">Частые вопросы</h2>
      </div>
      <div class="space-y-3">
        {faq.map((item) => (
          <details class="group bg-slate-50 border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between gap-4 cursor-pointer px-6 py-5 font-semibold text-slate-800 list-none">
              {item.q}
              <i class="fa-solid fa-chevron-down text-slate-400 text-sm transition-transform group-open:rotate-180 shrink-0"></i>
            </summary>
            <p class="px-6 pb-5 -mt-1 text-slate-600 text-sm leading-relaxed">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- ───────────── Финальный CTA ───────────── -->
  <section class="py-20 bg-gradient-to-br from-primary to-purple-600 text-white relative overflow-hidden">
    <div class="absolute -top-16 -right-16 w-80 h-80 bg-white/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Запустите умные QR-коды уже сегодня
      </h2>
      <p class="text-indigo-100 text-lg mb-8 max-w-xl mx-auto">
        Регистрация занимает минуту, бесплатный тариф — навсегда. Карта не нужна.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href={APP_URL} class="bg-white text-primary px-8 py-4 rounded-xl font-bold text-lg hover:bg-slate-100 transition shadow-lg">
          Начать бесплатно
        </a>
        <a href="#demo" class="bg-white/10 border border-white/30 text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-white/20 transition backdrop-blur-sm">
          Посмотреть демо
        </a>
      </div>
    </div>
  </section>

  <script is:inline>
    function setPeriod(period) {
      const monthlyEls = document.querySelectorAll('.price-monthly');
      const annualEls = document.querySelectorAll('.price-annual');
      const btnM = document.getElementById('btn-monthly');
      const btnA = document.getElementById('btn-annual');
      if (period === 'annual') {
        monthlyEls.forEach((el) => el.classList.add('hidden'));
        annualEls.forEach((el) => el.classList.remove('hidden'));
        btnA.classList.add('bg-white', 'text-slate-900');
        btnA.classList.remove('text-slate-400', 'hover:text-white');
        btnM.classList.remove('bg-white', 'text-slate-900');
        btnM.classList.add('text-slate-400', 'hover:text-white');
      } else {
        annualEls.forEach((el) => el.classList.add('hidden'));
        monthlyEls.forEach((el) => el.classList.remove('hidden'));
        btnM.classList.add('bg-white', 'text-slate-900');
        btnM.classList.remove('text-slate-400', 'hover:text-white');
        btnA.classList.remove('bg-white', 'text-slate-900');
        btnA.classList.add('text-slate-400', 'hover:text-white');
      }
    }
  </script>
</Layout>
