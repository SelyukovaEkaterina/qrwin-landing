---
import Layout from '../layouts/Layout.astro';
import TryDemoSection from '../components/TryDemoSection.astro';
import { appendAttributionParams } from '../lib/utm';

const APP_URL = appendAttributionParams('https://app.qrstars.ru', Astro.url.searchParams);

const trustSignals = [
  { icon: 'fa-map-location-dot', text: 'Яндекс Карты, 2GIS и Google' },
  { icon: 'fa-mobile-screen', text: 'Гостю не нужно приложение' },
  { icon: 'fa-route', text: 'Редирект меняется после печати' },
  { icon: 'fa-shield-halved', text: 'Оплата через ЮKassa · 54-ФЗ' },
];

const steps = [
  {
    icon: 'fa-user-plus',
    title: 'Зарегистрируйтесь бесплатно',
    text: 'Создайте кабинет за минуту — без карты и договора. Сразу доступен бесплатный тариф навсегда.',
  },
  {
    icon: 'fa-sliders',
    title: 'Настройте нужные сценарии',
    text: 'Отзывы, меню, визитки, Wi-Fi, файлы и рекламные редиректы настраиваются в одном кабинете.',
  },
  {
    icon: 'fa-qrcode',
    title: 'Разместите QR — и меняйте всё онлайн',
    text: 'Печатайте таблички, баннеры и бейджи один раз. Ссылки, меню и контент меняются без новой полиграфии.',
  },
];

const faq = [
  {
    q: 'Сколько стоит и нужна ли карта при регистрации?',
    a: 'Бесплатный тариф — навсегда: одно заведение, умные отзывы, все режимы QR и базовая аналитика. Регистрация занимает минуту, банковская карта не нужна. PRO — от 690 ₽/мес, если нужны ваш бренд вместо вотермарки, уведомления в Telegram и расширенная аналитика.',
  },
  {
    q: 'Нужно ли гостю устанавливать приложение?',
    a: 'Нет. Гость сканирует QR камерой телефона — страница открывается в обычном браузере за пару секунд. Скачиваний, регистраций и логинов не требуется.',
  },
  {
    q: 'Как работает умная фильтрация отзывов?',
    a: 'Гость ставит оценку от 1 до 5 звёзд. Довольным (4–5★) предлагается оставить отзыв на Яндекс Картах, 2GIS или другой площадке — одним нажатием. При низкой оценке гость сначала пишет вам напрямую, чтобы вы успели решить проблему до публичного отзыва.',
  },
  {
    q: 'Это законно? Вы не «накручиваете» отзывы?',
    a: 'Накрутки нет. Отзыв на картах оставляет реальный гость от своего имени — QrStars лишь упрощает путь довольному клиенту и помогает узнать о проблеме раньше, чем она появится на картах.',
  },
  {
    q: 'Можно ли менять меню, ссылки и акции без перепечатки?',
    a: 'Да — это главное преимущество динамических QR. Напечатанный код остаётся прежним, а содержимое меняется в кабинете: цены, стоп-лист, редирект на акцию или новый лендинг обновляются за минуту.',
  },
  {
    q: 'Чем PRO отличается от бесплатного тарифа?',
    a: 'На FREE уже работают отзывы, меню, визитки и все режимы QR — но с вотермаркой QrStars, уведомлениями на email и одной площадкой для 5★. PRO добавляет White Label, мгновенные уведомления в Telegram и MAX, ротацию площадок, промокоды за отзыв и расширенную аналитику. Сравнить тарифы можно в блоке выше.',
  },
  {
    q: 'Что будет, если не продлить подписку?',
    a: 'QR-коды продолжают работать — гости смогут сканировать, оставлять отзывы и чаевые. Ограничатся только инструменты управления: фото в меню скроются, кастомный дизайн сбросится. Есть льготный период 7 дней, чтобы успеть продлить.',
  },
  {
    q: 'Подходит ли QrStars для сети или франшизы?',
    a: 'Да. Тариф «Сеть» объединяет все точки в одном кабинете: сводный дашборд, роли для управляющих, выгрузка в CSV и White Label на уровне бренда. Два заведения включены, каждая дополнительная точка — +350 ₽/мес.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
};
---

<Layout
  title="QrStars — умные QR-коды для бизнеса"
  description="QR-платформа для офлайн-бизнеса: умные отзывы, электронное меню, динамические QR-коды с редиректом, визитки, файлы и аналитика в одном кабинете."
  yandexVerification="3dc4de0473e128f8"
>
  <!-- ───────────── Главный экран ───────────── -->
  <section class="pt-32 pb-16 lg:pt-40 lg:pb-20 overflow-hidden bg-white relative">
    <div
      class="absolute top-20 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-primary/5 rounded-full blur-3xl pointer-events-none"
    >
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative">
      <div
        class="inline-flex items-center gap-2 bg-primary/10 text-primary font-semibold px-4 py-1.5 rounded-full text-sm mb-6 border border-primary/20"
      >
        <i class="fa-solid fa-star"></i>
        QR-платформа для заведений, сервисов и офлайн-рекламы
      </div>
      <h1
        class="text-3xl md:text-4xl lg:text-[3.25rem] font-extrabold tracking-tight leading-[1.1] mb-6 max-w-4xl mx-auto"
      >
        Умные QR-коды для бизнеса —
        <span class="bg-gradient-to-r from-primary to-purple-500 gradient-text">
          отзывы, меню и рекламные редиректы
        </span>
      </h1>
      <p class="text-lg md:text-xl text-slate-600 mb-9 max-w-2xl mx-auto leading-relaxed">
        Собирайте отзывы на картах, обновляйте QR-меню и меняйте ссылки на баннерах,
        бейджах или табличках уже после печати. Всё управляется в одном кабинете и
        открывается в обычном браузере телефона.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href={APP_URL}
          data-goal="hero_start"
          class="bg-primary text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-indigo-700 transition shadow-lg shadow-indigo-500/30"
        >
          Начать бесплатно
        </a>
        <a
          href="#demo"
          class="bg-white text-slate-700 border border-slate-200 px-8 py-4 rounded-xl font-bold text-lg hover:bg-slate-50 transition shadow-sm"
        >
          <i class="fa-solid fa-mobile-screen-button mr-1.5 text-primary"></i>
          Посмотреть демо
        </a>
      </div>
      <p class="mt-4 text-sm text-slate-500">
        Бесплатный тариф навсегда · PRO от 690 ₽/мес · возврат в течение 14 дней
      </p>

      <ul
        class="mt-12 grid sm:grid-cols-2 gap-x-8 gap-y-3 max-w-3xl mx-auto text-left text-sm md:text-base text-slate-600"
      >
        <li class="flex items-start gap-3">
          <i class="fa-solid fa-circle-check text-primary mt-1 shrink-0"></i>
          <span><strong class="text-slate-800">Один кабинет:</strong> отзывы, меню, визитки, Wi-Fi, файлы и редиректы.</span>
        </li>
        <li class="flex items-start gap-3">
          <i class="fa-solid fa-circle-check text-primary mt-1 shrink-0"></i>
          <span><strong class="text-slate-800">Динамические QR:</strong> меняйте целевую ссылку без перепечатки макетов.</span>
        </li>
        <li class="flex items-start gap-3">
          <i class="fa-solid fa-circle-check text-primary mt-1 shrink-0"></i>
          <span><strong class="text-slate-800">Открывается мгновенно:</strong> обычный браузер телефона, без скачивания приложений.</span>
        </li>
        <li class="flex items-start gap-3">
          <i class="fa-solid fa-circle-check text-primary mt-1 shrink-0"></i>
          <span><strong class="text-slate-800">Умные отзывы:</strong> довольных — на карты, спорные ситуации — сначала руководителю.</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- ───────────── Полоса доверия ───────────── -->
  <section class="bg-slate-50 border-y border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {trustSignals.map((s) => (
          <div class="flex items-center justify-center gap-2.5 text-slate-600 text-sm font-medium">
            <i class={`fa-solid ${s.icon} text-primary`}></i>
            <span>{s.text}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ───────────── Проблема → Решение ───────────── -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <div
          class="inline-block bg-rose-50 text-rose-600 font-semibold px-4 py-1.5 rounded-full text-sm mb-4 border border-rose-100"
        >
          Почему это важно
        </div>
        <h2 class="text-3xl font-bold mb-4 max-w-2xl mx-auto">
          Рейтинг на картах и печатные QR нельзя оставлять без управления
        </h2>
        <p class="text-slate-600 max-w-2xl mx-auto leading-relaxed">
          Недовольный гость быстро пишет публичный отзыв, довольный часто молчит,
          а напечатанный QR со старой ссылкой продолжает вести не туда. QrStars
          помогает управлять этими точками контакта из одного кабинета.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <div class="bg-slate-50 border border-slate-200 rounded-2xl p-7">
          <div
            class="w-12 h-12 bg-rose-100 text-rose-500 rounded-xl flex items-center justify-center mb-4 text-xl"
          >
            <i class="fa-solid fa-face-frown"></i>
          </div>
          <h3 class="font-bold text-lg mb-3">Без QrStars</h3>
          <ul class="space-y-2.5 text-sm text-slate-600">
            <li class="flex gap-2.5"><i class="fa-solid fa-xmark text-rose-400 mt-1 shrink-0"></i> Негатив сразу попадает на публичные карты</li>
            <li class="flex gap-2.5"><i class="fa-solid fa-xmark text-rose-400 mt-1 shrink-0"></i> Довольные гости не доходят до отзыва</li>
            <li class="flex gap-2.5"><i class="fa-solid fa-xmark text-rose-400 mt-1 shrink-0"></i> О проблеме узнаёте, когда уже поздно</li>
            <li class="flex gap-2.5"><i class="fa-solid fa-xmark text-rose-400 mt-1 shrink-0"></i> Баннеры, меню и таблички перепечатываются при смене ссылок</li>
          </ul>
        </div>
        <div class="bg-primary/5 border border-primary/20 rounded-2xl p-7">
          <div
            class="w-12 h-12 bg-primary/10 text-primary rounded-xl flex items-center justify-center mb-4 text-xl"
          >
            <i class="fa-solid fa-face-smile"></i>
          </div>
          <h3 class="font-bold text-lg mb-3">С QrStars</h3>
          <ul class="space-y-2.5 text-sm text-slate-700">
            <li class="flex gap-2.5"><i class="fa-solid fa-check text-primary mt-1 shrink-0"></i> Довольным гостям проще оставить отзыв на картах</li>
            <li class="flex gap-2.5"><i class="fa-solid fa-check text-primary mt-1 shrink-0"></i> Спорные ситуации сначала приходят лично вам</li>
            <li class="flex gap-2.5"><i class="fa-solid fa-check text-primary mt-1 shrink-0"></i> Проблему решаете до того, как её увидят все</li>
            <li class="flex gap-2.5"><i class="fa-solid fa-check text-primary mt-1 shrink-0"></i> Меню, файлы и рекламные редиректы меняются онлайн</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <TryDemoSection />

  <!-- ───────────── Как это работает ───────────── -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <div
          class="inline-block bg-primary/10 text-primary font-semibold px-4 py-1.5 rounded-full text-sm mb-4 border border-primary/20"
        >
          Запуск за 10 минут
        </div>
        <h2 class="text-3xl font-bold mb-4">Как это работает</h2>
        <p class="text-slate-600 max-w-2xl mx-auto">
          Три шага от регистрации до первых сканов — без программистов, дизайнеров
          и долгих внедрений.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 relative">
        {steps.map((step, i) => (
          <div class="bg-slate-50 border border-slate-100 rounded-2xl p-7 relative">
            <div class="flex items-center gap-3 mb-4">
              <div
                class="w-12 h-12 bg-primary text-white rounded-xl flex items-center justify-center text-xl shrink-0"
              >
                <i class={`fa-solid ${step.icon}`}></i>
              </div>
              <span class="text-5xl font-extrabold text-slate-200">{i + 1}</span>
            </div>
            <h3 class="font-bold text-lg mb-2">{step.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{step.text}</p>
          </div>
        ))}
      </div>

      <div class="text-center mt-10">
        <a
          href={APP_URL}
          data-goal="howto_register"
          class="inline-flex items-center gap-2 bg-primary text-white px-8 py-3.5 rounded-xl font-bold hover:bg-indigo-700 transition shadow-lg shadow-indigo-500/20"
        >
          Создать кабинет бесплатно
          <i class="fa-solid fa-arrow-right text-sm"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- ───────────── Все возможности ───────────── -->
  <section id="features" class="py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold mb-4">Все QR-сценарии бизнеса — в одном кабинете</h2>
        <p class="text-slate-600 max-w-2xl mx-auto">
          QrStars объединяет отзывы, электронное меню, динамические редиректы,
          QR-файлы, визитки сотрудников и аналитику. Без приложений и сложных
          настроек — подключите свои QR-коды или активируйте готовую табличку.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Умные отзывы -->
        <a
          href="/smart-reviews.html"
          class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition feature-card group block"
        >
          <div class="w-14 h-14 bg-amber-100 rounded-xl flex items-center justify-center mb-6">
            <i class="fa-solid fa-star text-2xl text-amber-500 group-hover:scale-110 transition"></i>
          </div>
          <h3 class="font-bold text-xl mb-3">Умные отзывы</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Довольным клиентам проще оставить отзыв на Яндекс и 2GIS. Спорные
            ситуации сначала приходят лично вам, чтобы вы успели разобраться.
          </p>
          <span class="inline-block mt-4 text-primary text-sm font-semibold group-hover:underline">Подробнее об отзывах →</span>
        </a>

        <!-- QR-меню -->
        <a
          href="/qr-menu.html"
          class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition feature-card group block"
        >
          <div class="w-14 h-14 bg-lime-100 rounded-xl flex items-center justify-center mb-6">
            <i class="fa-solid fa-utensils text-2xl text-lime-600 group-hover:scale-110 transition"></i>
          </div>
          <h3 class="font-bold text-xl mb-3">
            QR-меню
            <span class="text-xs font-semibold text-amber-700 bg-amber-100 px-2 py-0.5 rounded-full ml-1 align-middle">PRO</span>
          </h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Гибкий конструктор: категории, фотографии и актуальные цены. Скрывайте
            закончившиеся позиции в кабинете — QR-код на столиках остаётся прежним.
          </p>
          <span class="inline-block mt-4 text-primary text-sm font-semibold group-hover:underline">Подробнее о меню →</span>
        </a>

        <!-- QR-файлы -->
        <a
          href="/file-sharing.html"
          class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition feature-card group block"
        >
          <div class="w-14 h-14 bg-orange-100 rounded-xl flex items-center justify-center mb-6">
            <i class="fa-solid fa-file-arrow-down text-2xl text-orange-500 group-hover:scale-110 transition"></i>
          </div>
          <h3 class="font-bold text-xl mb-3">
            QR-файлы
            <span class="text-xs font-semibold text-amber-700 bg-amber-100 px-2 py-0.5 rounded-full ml-1 align-middle">PRO</span>
          </h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            PDF-меню, прайс-листы, каталоги и инструкции обновляются за минуту.
            Клиент скачивает файл в телефон, а вы меняете его без перепечатки.
          </p>
          <span class="inline-block mt-4 text-primary text-sm font-semibold group-hover:underline">Подробнее про QR-файлы →</span>
        </a>

        <!-- Визитки сотрудников -->
        <a
          href="/qr-business-cards.html"
          class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition feature-card group block"
        >
          <div class="w-14 h-14 bg-blue-100 rounded-xl flex items-center justify-center mb-6">
            <i class="fa-solid fa-id-badge text-2xl text-blue-500 group-hover:scale-110 transition"></i>
          </div>
          <h3 class="font-bold text-xl mb-3">
            Визитки сотрудников
            <span class="text-xs font-semibold text-amber-700 bg-amber-100 px-2 py-0.5 rounded-full ml-1 align-middle">PRO</span>
          </h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Электронные визитки команды: клиент сохраняет контакты в один клик и
            оставляет чаевые напрямую. Без комиссий — просто удобная кнопка.
          </p>
          <span class="inline-block mt-4 text-primary text-sm font-semibold group-hover:underline">Подробнее о визитках →</span>
        </a>

        <!-- Динамические QR -->
        <a
          href="/dynamic-qr.html"
          class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition feature-card group block"
        >
          <div class="w-14 h-14 bg-green-100 rounded-xl flex items-center justify-center mb-6">
            <i class="fa-solid fa-link text-2xl text-green-500 group-hover:scale-110 transition"></i>
          </div>
          <h3 class="font-bold text-xl mb-3">Динамические QR</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            QR-код кодирует короткий URL&nbsp;— <code>app.qrstars.ru/q/…</code>,
            а целевой адрес можно менять в панели без замены баннеров, бейджей,
            наклеек и&nbsp;табличек.
          </p>
          <span class="inline-block mt-4 text-primary text-sm font-semibold group-hover:underline">Подробнее о редиректах →</span>
        </a>

        <!-- Подробная статистика -->
        <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition feature-card group">
          <div class="w-14 h-14 bg-purple-100 rounded-xl flex items-center justify-center mb-6">
            <i class="fa-solid fa-chart-pie text-2xl text-purple-500 group-hover:scale-110 transition"></i>
          </div>
          <h3 class="font-bold text-xl mb-3">Подробная статистика</h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            Отслеживайте каждое сканирование. Узнавайте, какие столики, мастера,
            филиалы, баннеры или стенды приносят больше переходов и отзывов.
          </p>
        </div>

        <!-- Бесплатный генератор QR -->
        <a
          href="/free-qr-generator.html"
          data-goal="qr_generator_link"
          data-goal-params='{"source":"home_features"}'
          class="bg-white p-8 rounded-2xl border border-emerald-200 shadow-sm hover:shadow-md transition feature-card group block relative"
        >
          <div class="absolute top-6 right-6 bg-emerald-100 text-emerald-700 text-xs font-bold px-2.5 py-1 rounded-full">Бесплатно</div>
          <div class="w-14 h-14 bg-emerald-100 rounded-xl flex items-center justify-center mb-6">
