      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href={APP_URL} data-goal="bottom_cta" class="bg-white text-primary px-8 py-4 rounded-xl font-bold text-lg hover:bg-slate-100 transition shadow-lg">
          Начать бесплатно
        </a>
        <a href="#demo" class="bg-white/10 border border-white/30 text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-white/20 transition backdrop-blur-sm">
          Посмотреть демо
        </a>
      </div>
    </div>
  </section>

  <script is:inline>
    function setPeriod(period) {
      const monthlyEls = document.querySelectorAll('.price-monthly');
      const annualEls = document.querySelectorAll('.price-annual');
      const btnM = document.getElementById('btn-monthly');
      const btnA = document.getElementById('btn-annual');
      if (period === 'annual') {
        monthlyEls.forEach((el) => el.classList.add('hidden'));
        annualEls.forEach((el) => el.classList.remove('hidden'));
        btnA.classList.add('bg-white', 'text-slate-900');
        btnA.classList.remove('text-slate-400', 'hover:text-white');
        btnM.classList.remove('bg-white', 'text-slate-900');
        btnM.classList.add('text-slate-400', 'hover:text-white');
      } else {
        annualEls.forEach((el) => el.classList.add('hidden'));
        monthlyEls.forEach((el) => el.classList.remove('hidden'));
        btnM.classList.add('bg-white', 'text-slate-900');
        btnM.classList.remove('text-slate-400', 'hover:text-white');
        btnA.classList.remove('bg-white', 'text-slate-900');
        btnA.classList.add('text-slate-400', 'hover:text-white');
      }
    }
  </script>
</Layout>
