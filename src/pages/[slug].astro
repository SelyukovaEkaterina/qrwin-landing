---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SeoHero from '../components/seo/SeoHero.astro';
import HowItWorks from '../components/seo/HowItWorks.astro';
import ForWhom from '../components/seo/ForWhom.astro';
import Faq from '../components/seo/Faq.astro';
import QrExamples from '../components/seo/QrExamples.astro';
import DemoQrScan from '../components/DemoQrScan.astro';
import SeoCta from '../components/seo/SeoCta.astro';
import RelatedPages from '../components/seo/RelatedPages.astro';
import StickyRegisterCta from '../components/seo/StickyRegisterCta.astro';
import {
  appendAttributionParams,
  isAppUrl,
  REVIEWS_LANDING_SLUGS,
  MENU_LANDING_SLUGS,
} from '../lib/utm';

export async function getStaticPaths() {
  const seoPages = await getCollection('seo');
  return seoPages.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;

const rawCtaHref = d.ctaHref;
const ctaHref = isAppUrl(rawCtaHref) ? appendAttributionParams(rawCtaHref, Astro.url.searchParams) : rawCtaHref;
const ctaExternal = isAppUrl(rawCtaHref);
const ctaGoal = d.ctaGoal ?? (ctaExternal ? 'hero_start' : undefined);

const rawSecondaryHref = d.ctaSecondaryHref;
const ctaSecondaryHref =
  rawSecondaryHref && isAppUrl(rawSecondaryHref)
    ? appendAttributionParams(rawSecondaryHref, Astro.url.searchParams)
    : rawSecondaryHref;
const ctaSecondaryExternal = Boolean(rawSecondaryHref && isAppUrl(rawSecondaryHref));
const ctaSecondaryGoal =
  d.ctaSecondaryGoal ?? (ctaSecondaryExternal ? 'qr_dynamic_cta' : undefined);

const showStickyCta = d.stickyCta ?? (REVIEWS_LANDING_SLUGS.has(entry.slug) || MENU_LANDING_SLUGS.has(entry.slug));

const pageCanonical = `https://qrstars.ru/${entry.slug}.html`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: 'https://qrstars.ru/' },
    { '@type': 'ListItem', position: 2, name: d.h1, item: pageCanonical },
  ],
};

const softwareApplicationSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'QrStars',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  url: pageCanonical,
  description: d.description,
  inLanguage: 'ru-RU',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'RUB',
    availability: 'https://schema.org/InStock',
    url: pageCanonical,
  },
  publisher: {
    '@type': 'Organization',
    name: 'QrStars',
    url: 'https://qrstars.ru',
  },
};

const defaultSteps = [
  { icon: 'fa-solid fa-link', title: 'Вставьте ссылку', text: 'Укажите URL, контакты или выберите шаблон для отзывов, меню или WiFi.' },
  { icon: 'fa-solid fa-palette', title: 'Настройте дизайн', text: 'Добавьте логотип, фирменные цвета и рамку — код останется читаемым.' },
  { icon: 'fa-solid fa-download', title: 'Скачайте QR', text: 'Получите PNG или SVG для печати на табличках, визитках и меню.' },
  { icon: 'fa-solid fa-chart-line', title: 'Смотрите аналитику', text: 'Отслеживайте сканирования и меняйте ссылку без перепечатки (динамический QR).' },
];

const defaultIndustries = [
  { icon: 'fa-solid fa-utensils', name: 'Кафе и рестораны' },
  { icon: 'fa-solid fa-scissors', name: 'Салоны красоты' },
  { icon: 'fa-solid fa-hospital', name: 'Клиники' },
  { icon: 'fa-solid fa-store', name: 'Магазины' },
  { icon: 'fa-solid fa-calendar', name: 'Мероприятия' },
];
---

<Layout
  title={d.title}
  description={d.description}
  fullTitle={d.fullTitle}
  canonical={pageCanonical}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(softwareApplicationSchema)} />
  <SeoHero
    badge={d.badge}
    h1={d.h1}
    intro={d.intro}
    ctaText={d.ctaText}
    ctaHref={ctaHref}
    ctaSecondaryText={d.ctaSecondaryText}
    ctaSecondaryHref={ctaSecondaryHref}
    ctaGoal={ctaGoal}
    ctaExternal={ctaExternal}
    ctaSecondaryGoal={ctaSecondaryGoal}
    ctaSecondaryExternal={ctaSecondaryExternal}
  />

  {d.demoScanUrl && (
    <DemoQrScan
      scanUrl={d.demoScanUrl}
      modeLabel={d.demoScanLabel ?? d.h1}
      title={d.demoScanTitle}
      subtitle={d.demoScanSubtitle}
    />
  )}

  <section class="py-12 lg:py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <article class="prose prose-slate lg:prose-lg max-w-none">
        <Content />
      </article>
    </div>
  </section>

  <HowItWorks steps={d.howItWorks ?? defaultSteps} />
  <ForWhom industries={d.forWhom ?? defaultIndustries} />
  {!d.demoScanUrl && <QrExamples />}
  <Faq items={d.faq} />
  {d.related && <RelatedPages links={d.related} />}
  <SeoCta ctaText={d.ctaText} ctaHref={ctaHref} ctaGoal={ctaGoal} ctaExternal={ctaExternal} />
  {showStickyCta && ctaExternal && (
    <StickyRegisterCta href={ctaHref} />
  )}
</Layout>
