---
import Layout from '../layouts/Layout.astro';
import DemoQrScan from '../components/DemoQrScan.astro';

const DEMO_SCAN_URL = 'https://app.qrstars.ru/scan/demo-review';
---

<Layout title="Умные отзывы" description="Получайте 5 звезд, перехватывайте негатив. Скачайте PDF-макет в личном кабинете и распечатайте табличку самостоятельно.">
    <section class="pt-32 pb-20 lg:pt-40 lg:pb-28 overflow-hidden bg-slate-50 relative">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <!-- Левая часть: Текст -->
                <div class="z-10">
                    <div class="inline-block bg-blue-100 text-blue-700 font-semibold px-4 py-1.5 rounded-full text-sm mb-6 border border-blue-200">
                        🔥 Спасите рейтинг вашего бизнеса
                    </div>
                    <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight mb-6">
                        Получайте <span class="text-transparent bg-clip-text bg-gradient-to-r from-yandex to-orange-500">5 звёзд</span>,<br>
                        перехватывайте <span class="text-red-500">негатив</span>.
                    </h1>
                    <p class="text-lg md:text-xl text-slate-600 mb-6 max-w-lg leading-relaxed">
                        Один QR на столе решает две задачи: растит публичный рейтинг (5★ на Яндекс и 2GIS) и защищает репутацию — негатив уходит лично вам, а не в интернет.
                    </p>
                    <p class="text-sm text-slate-500 mb-8 max-w-lg leading-relaxed">
                        <strong class="text-slate-700">Разместите QR на столе:</strong> скачайте PDF-макет в личном кабинете и распечатайте в любой типографии или на офисном принтере — сервис работает сразу после настройки.
                    </p>
                    
                    <div class="flex flex-col sm:flex-row gap-4">
                        <a href="https://app.qrstars.ru" class="flex items-center justify-center gap-3 bg-primary text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-indigo-700 transition shadow-lg shadow-indigo-500/30">
                            Создать табличку
                            <i class="fa-solid fa-arrow-right"></i>
                        </a>
                        <a href="/#buy" class="flex items-center justify-center gap-2 bg-white text-slate-800 border border-slate-200 px-8 py-4 rounded-xl font-bold text-lg hover:bg-slate-50 transition shadow-sm">
                            <i class="fa-solid fa-print text-slate-500"></i>
                            Скачать PDF-макет
                        </a>
                    </div>
                </div>

                <!-- Правая часть: Интерактивное демо -->
                <div class="relative flex justify-center lg:justify-end">
                    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-72 h-72 bg-blue-400 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-pulse"></div>
                    
                    <!-- Телефон -->
                    <div class="phone-mockup w-[320px] h-[600px] z-10 bg-white flex flex-col shadow-2xl border-[8px] border-slate-800 rounded-[2.5rem] relative overflow-hidden">
                        <div class="w-full h-6 bg-slate-800 absolute top-0 z-20 flex justify-center">
                            <div class="w-1/3 h-4 bg-slate-800 rounded-b-xl"></div>
                        </div>
                        
                        <!-- Экран демо -->
                        <div class="flex-1 flex flex-col p-6 pt-12 relative transition-opacity duration-300" id="demo-main">
                            <div class="text-center mb-8 mt-4">
                                <div class="w-16 h-16 bg-slate-100 rounded-full mx-auto mb-4 flex items-center justify-center">
                                    <i class="fa-solid fa-mug-hot text-2xl text-slate-500"></i>
                                </div>
                                <h3 class="font-bold text-xl">Кофейня "Зерно"</h3>
                                <p class="text-slate-500 text-sm">Оцените ваш визит</p>
                            </div>
                            
                            <!-- Звезды -->
                            <div class="flex justify-center gap-2 mb-12">
                                <button class="star-btn text-4xl text-slate-300 hover:scale-125 transition-transform" data-rating="1"><i class="fa-solid fa-star pointer-events-none"></i></button>
                                <button class="star-btn text-4xl text-slate-300 hover:scale-125 transition-transform" data-rating="2"><i class="fa-solid fa-star pointer-events-none"></i></button>
                                <button class="star-btn text-4xl text-slate-300 hover:scale-125 transition-transform" data-rating="3"><i class="fa-solid fa-star pointer-events-none"></i></button>
                                <button class="star-btn text-4xl text-slate-300 hover:scale-125 transition-transform" data-rating="4"><i class="fa-solid fa-star pointer-events-none"></i></button>
                                <button class="star-btn text-4xl text-slate-300 hover:scale-125 transition-transform" data-rating="5"><i class="fa-solid fa-star pointer-events-none"></i></button>
                            </div>

                            <div class="mt-auto text-center">
                                <p class="text-xs text-slate-400">Нажмите на звезду, чтобы увидеть магию 👆</p>
                            </div>
                        </div>

                        <!-- Экран: Плохой отзыв -->
                        <div class="hidden flex-1 flex-col p-6 pt-20 text-center bg-red-50" id="demo-bad">
                            <i class="fa-solid fa-face-frown text-5xl text-red-400 mb-4"></i>
                            <h3 class="font-bold text-lg mb-2">Нам очень жаль!</h3>
                            <p class="text-sm text-slate-600 mb-6">Расскажите, что пошло не так? Сообщение отправится лично директору.</p>
                            <textarea class="w-full h-32 p-3 rounded-xl border border-red-200 text-sm mb-4 bg-white" placeholder="Кофе был холодным..."></textarea>
                            <button class="reset-demo-btn w-full bg-slate-900 text-white py-3 rounded-xl font-bold">Отправить директору</button>
                            <p class="text-xs text-red-500 mt-4 font-semibold"><i class="fa-solid fa-shield-halved"></i> Отзыв не попал в интернет</p>
                        </div>

                        <!-- Экран: Хороший отзыв -->
                        <div class="hidden flex-1 flex-col p-6 pt-20 text-center bg-green-50" id="demo-good">
                            <i class="fa-solid fa-face-smile text-5xl text-green-500 mb-4"></i>
                            <h3 class="font-bold text-lg mb-2">Супер! Спасибо!</h3>
                            <p class="text-sm text-slate-600 mb-8">Пожалуйста, поделитесь впечатлениями на картах.</p>
                            <button class="reset-demo-btn w-full bg-yandex text-black py-3 rounded-xl font-bold mb-3 flex items-center justify-center gap-2">
                                Оставить на Яндексе
                            </button>
                            <button class="reset-demo-btn w-full bg-dgis text-white py-3 rounded-xl font-bold flex items-center justify-center gap-2">
                                Оставить в 2GIS
                            </button>
                            <p class="text-xs text-green-600 mt-4 font-semibold"><i class="fa-solid fa-arrow-trend-up"></i> Рейтинг растет</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <DemoQrScan
        scanUrl={DEMO_SCAN_URL}
        modeLabel="Умные отзывы"
        title="Отсканируйте демо отзывов"
        subtitle="Увидите сценарий оценки: 5★ уходят на карты, негатив — лично вам, без публикации в интернете"
    />

    <!-- Распечатать табличку -->
    <section class="py-16 bg-white border-b border-slate-200">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-10">
                <h2 class="text-2xl md:text-3xl font-bold mb-3">Распечатайте табличку за 5 минут</h2>
                <p class="text-slate-600 max-w-2xl mx-auto">Соберите тейбл-тент в кабинете, скачайте PDF и поставьте на стол — QR остаётся динамическим, ссылку можно менять без перепечатки.</p>
            </div>
            <div class="bg-slate-50 border border-slate-200 rounded-2xl p-8">
                <div class="w-12 h-12 bg-teal-100 text-teal-600 rounded-xl flex items-center justify-center mb-5">
                    <i class="fa-solid fa-print text-xl"></i>
                </div>
                <h3 class="font-bold text-xl mb-2">PDF-макет в личном кабинете</h3>
                <p class="text-slate-600 text-sm leading-relaxed mb-6">Добавьте логотип и фирменные цвета, скачайте готовый макет и распечатайте в типографии или на офисном принтере.</p>
                <ul class="space-y-2 text-sm text-slate-700 mb-6">
                    <li class="flex items-start gap-2"><i class="fa-solid fa-check text-teal-500 mt-0.5"></i> Бесплатно в базовом тарифе</li>
                    <li class="flex items-start gap-2"><i class="fa-solid fa-check text-teal-500 mt-0.5"></i> Логотип и цвета вашего бренда</li>
                    <li class="flex items-start gap-2"><i class="fa-solid fa-check text-teal-500 mt-0.5"></i> Ссылку можно менять без перепечатки</li>
                </ul>
                <a href="https://app.qrstars.ru" class="inline-flex items-center gap-2 text-teal-600 font-semibold hover:underline">
                    Создать макет бесплатно <i class="fa-solid fa-arrow-right text-sm"></i>
                </a>
            </div>
        </div>
    </section>

    <!-- Блок "Как это работает" -->
    <section class="py-20 bg-white border-y border-slate-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16">
                <h2 class="text-3xl font-bold mb-4">Как это работает? Без программистов и настроек.</h2>
                <p class="text-slate-600">Скачайте PDF-макет, распечатайте табличку — дальше всё просто: один QR, одна настройка, умная фильтрация отзывов.</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Шаг 1 -->
                <div class="bg-slate-50 p-8 rounded-2xl text-center border border-slate-100 relative">
                    <div class="absolute -top-5 left-1/2 -translate-x-1/2 w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold text-lg">1</div>
                    <i class="fa-solid fa-tablet-screen-button text-4xl text-blue-500 mb-6 mt-2"></i>
                    <h3 class="font-bold text-xl mb-3">Распечатайте табличку</h3>
                    <p class="text-slate-600 text-sm">Скачайте PDF-макет в личном кабинете и распечатайте тейбл-тент в типографии или на офисном принтере.</p>
                </div>
                <!-- Шаг 2 -->
                <div class="bg-slate-50 p-8 rounded-2xl text-center border border-slate-100 relative">
                    <div class="absolute -top-5 left-1/2 -translate-x-1/2 w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold text-lg">2</div>
                    <i class="fa-solid fa-qrcode text-4xl text-blue-500 mb-6 mt-2"></i>
                    <h3 class="font-bold text-xl mb-3">Отсканируйте 1 раз</h3>
                    <p class="text-slate-600 text-sm">Отсканируйте QR-код своим телефоном и введите название заведения. Код навсегда привяжется к вам.</p>
                </div>
                <!-- Шаг 3 -->
                <div class="bg-slate-50 p-8 rounded-2xl text-center border border-slate-100 relative">
                    <div class="absolute -top-5 left-1/2 -translate-x-1/2 w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold text-lg">3</div>
                    <i class="fa-solid fa-chart-line text-4xl text-blue-500 mb-6 mt-2"></i>
                    <h3 class="font-bold text-xl mb-3">Смотрите, как растет рейтинг</h3>
                    <p class="text-slate-600 text-sm">Поставьте табличку на столы. Сервис начнет фильтровать отзывы автоматически. Бесплатно.</p>
                </div>
            </div>
        </div>
    </section>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const stars = document.querySelectorAll('.star-btn');
            const mainScreen = document.getElementById('demo-main');
            const badScreen = document.getElementById('demo-bad');
            const goodScreen = document.getElementById('demo-good');
            const resetBtns = document.querySelectorAll('.reset-demo-btn');

            stars.forEach(star => {
                star.addEventListener('click', (e) => {
                    const rating = parseInt((e.currentTarget as HTMLElement).dataset.rating || '0');
                    if (mainScreen && badScreen && goodScreen) {
                        mainScreen.classList.add('opacity-0');
                        setTimeout(() => {
                            mainScreen.classList.add('hidden');
                            mainScreen.classList.remove('opacity-0');
                            if (rating <= 3) {
                                badScreen.classList.remove('hidden');
                            } else {
                                goodScreen.classList.remove('hidden');
                            }
                        }, 300);
                    }
                });
            });

            resetBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    if (mainScreen && badScreen && goodScreen) {
                        badScreen.classList.add('hidden');
                        goodScreen.classList.add('hidden');
                        mainScreen.classList.remove('hidden');
                    }
                });
            });
        });
    </script>
</Layout>
