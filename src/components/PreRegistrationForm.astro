---
import { LEGAL_LINKS, PREREG_API_URL } from '../lib/legal';
---

<section id="prereg" class="py-20 bg-white border-t border-slate-200">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <div class="inline-block bg-primary/10 text-primary font-semibold px-4 py-1.5 rounded-full text-sm mb-4 border border-primary/20">
        Ранний доступ
      </div>
      <h2 class="text-3xl font-bold mb-4">Предрегистрация в QrStars</h2>
      <p class="text-slate-600 text-lg">
        Оставьте контакты — сообщим о запуске кабинета и подключим первыми к PRO-функциям.
      </p>
    </div>

    <form
      id="prereg-form"
      class="bg-slate-50 border border-slate-200 rounded-2xl p-6 sm:p-8 space-y-5 shadow-sm"
      data-api-url={PREREG_API_URL}
      novalidate
    >
      <div id="prereg-error" class="hidden bg-red-50 text-red-700 px-4 py-3 rounded-xl text-sm" role="alert"></div>
      <div id="prereg-success" class="hidden bg-green-50 text-green-800 px-4 py-3 rounded-xl text-sm" role="status">
        Спасибо! Заявка принята — мы свяжемся с вами по указанному email.
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="prereg-name" class="block text-sm font-medium text-slate-700 mb-1.5">Имя</label>
          <input
            type="text"
            id="prereg-name"
            name="name"
            autocomplete="name"
            class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition"
            placeholder="Иван"
          />
        </div>
        <div>
          <label for="prereg-phone" class="block text-sm font-medium text-slate-700 mb-1.5">Телефон</label>
          <input
            type="tel"
            id="prereg-phone"
            name="phone"
            autocomplete="tel"
            class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition"
            placeholder="+7 (999) 123-45-67"
          />
        </div>
      </div>

      <div>
        <label for="prereg-email" class="block text-sm font-medium text-slate-700 mb-1.5">Email <span class="text-red-500">*</span></label>
        <input
          type="email"
          id="prereg-email"
          name="email"
          required
          autocomplete="email"
          class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition"
          placeholder="you@company.ru"
        />
      </div>

      <label class="flex items-start gap-3 cursor-pointer group">
        <input
          type="checkbox"
          id="prereg-consent"
          name="consentPd"
          required
          class="mt-1 w-4 h-4 rounded border-slate-300 text-primary focus:ring-primary shrink-0"
        />
        <span class="text-sm text-slate-600 leading-relaxed">
          Даю
          <a href={LEGAL_LINKS.consent} target="_blank" rel="noopener noreferrer" class="text-primary font-medium hover:underline">
            согласие о передаче персональных данных
          </a>
          и подтверждаю ознакомление с
          <a href={LEGAL_LINKS.privacy} target="_blank" rel="noopener noreferrer" class="text-primary font-medium hover:underline">
            политикой конфиденциальности
          </a>.
        </span>
      </label>

      <button
        type="submit"
        id="prereg-submit"
        class="w-full bg-primary text-white px-6 py-4 rounded-xl font-bold text-lg hover:bg-indigo-700 transition shadow-lg shadow-indigo-500/20 disabled:opacity-60 disabled:cursor-not-allowed"
      >
        Отправить заявку
      </button>

      <p class="text-xs text-slate-400 text-center">
        Нажимая кнопку, вы подтверждаете согласие в соответствии с Федеральным законом № 152-ФЗ.
      </p>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('prereg-form') as HTMLFormElement | null;
  if (form) {
    const apiUrl = form.dataset.apiUrl || '';
    const errorEl = document.getElementById('prereg-error');
    const successEl = document.getElementById('prereg-success');
    const submitBtn = document.getElementById('prereg-submit') as HTMLButtonElement | null;
    const consent = document.getElementById('prereg-consent') as HTMLInputElement | null;

    const showError = (msg: string) => {
      if (errorEl) {
        errorEl.textContent = msg;
        errorEl.classList.remove('hidden');
      }
      successEl?.classList.add('hidden');
    };

    const hideError = () => errorEl?.classList.add('hidden');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      hideError();

      if (!consent?.checked) {
        showError('Необходимо дать согласие на обработку и передачу персональных данных.');
        return;
      }

      const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim();
      if (!email) {
        showError('Укажите email.');
        return;
      }

      const payload = {
        email,
        name: (form.elements.namedItem('name') as HTMLInputElement).value.trim() || undefined,
        phone: (form.elements.namedItem('phone') as HTMLInputElement).value.trim() || undefined,
        consentPd: true,
        source: 'landing-prereg',
      };

      if (submitBtn) submitBtn.disabled = true;

      try {
        const res = await fetch(apiUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.error || 'Не удалось отправить заявку. Попробуйте позже.');
        }

        form.reset();
        successEl?.classList.remove('hidden');
      } catch (err) {
        showError(err instanceof Error ? err.message : 'Ошибка отправки. Попробуйте позже.');
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  }
</script>
