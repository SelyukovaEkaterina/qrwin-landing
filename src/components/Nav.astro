---
const productLinks = [
  { href: '/smart-reviews.html', label: 'Умные отзывы' },
  { href: '/dynamic-qr.html', label: 'Динамические QR' },
  { href: '/qr-menu.html', label: 'QR-меню' },
  { href: '/qr-business-cards.html', label: 'QR-визитки' },
  { href: '/file-sharing.html', label: 'QR-файлы' },
];

const industryLinks = [
  { href: '/otraslevye-resheniya.html', label: 'Все отрасли' },
  { href: '/qr-kod-dlya-restorana.html', label: 'Рестораны и кафе' },
  { href: '/qr-kod-dlya-salona-krasoty.html', label: 'Салоны красоты' },
  { href: '/qr-kod-dlya-stomatologii.html', label: 'Стоматологии' },
  { href: '/qr-kod-dlya-avtoservisa.html', label: 'Автосервисы' },
];

import { appendAttributionParams, MENU_LANDING_PATHS, menuRegisterUrl } from '../lib/utm';
const APP_URL = appendAttributionParams('https://app.qrstars.ru', Astro.url.searchParams);
const isMenuLanding = MENU_LANDING_PATHS.has(Astro.url.pathname);
const REGISTER_CTA_URL = isMenuLanding
  ? menuRegisterUrl('nav-menu', Astro.url.searchParams)
  : APP_URL;
const REGISTER_CTA_TEXT = isMenuLanding ? 'Создать меню' : 'Начать бесплатно';
const REGISTER_CTA_GOAL = isMenuLanding ? 'hero_start' : 'nav_register';
---

<nav class="fixed w-full bg-white/90 backdrop-blur-md z-50 border-b border-slate-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16 items-center">
      <a href="/" class="flex-shrink-0 flex items-center gap-2">
        <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center text-white font-bold">QR</div>
        <span class="font-bold text-xl tracking-tight">QrStars</span>
      </a>

      <div class="hidden lg:flex items-center gap-2">
        <div class="relative group">
          <button type="button" class="inline-flex items-center gap-1.5 px-3 py-2 text-slate-600 hover:text-primary transition font-medium text-[15px]">
            Продукты
            <i class="fa-solid fa-chevron-down text-[10px] transition group-hover:rotate-180"></i>
          </button>
          <div class="invisible opacity-0 translate-y-2 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 group-focus-within:visible group-focus-within:opacity-100 group-focus-within:translate-y-0 absolute left-0 top-full w-64 pt-3 transition duration-150">
            <div class="rounded-2xl border border-slate-200 bg-white shadow-xl shadow-slate-900/10 p-2">
              {productLinks.map((link) => (
                <a href={link.href} class="block rounded-xl px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50 hover:text-primary transition">{link.label}</a>
              ))}
            </div>
          </div>
        </div>

        <div class="relative group">
          <button type="button" class="inline-flex items-center gap-1.5 px-3 py-2 text-slate-600 hover:text-primary transition font-medium text-[15px]">
            Отрасли
            <i class="fa-solid fa-chevron-down text-[10px] transition group-hover:rotate-180"></i>
          </button>
          <div class="invisible opacity-0 translate-y-2 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 group-focus-within:visible group-focus-within:opacity-100 group-focus-within:translate-y-0 absolute left-0 top-full w-72 pt-3 transition duration-150">
            <div class="rounded-2xl border border-slate-200 bg-white shadow-xl shadow-slate-900/10 p-2">
              {industryLinks.map((link) => (
                <a href={link.href} class="block rounded-xl px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50 hover:text-primary transition">{link.label}</a>
              ))}
            </div>
          </div>
        </div>

        <a href="/blog.html" class="px-3 py-2 text-slate-600 hover:text-primary transition font-medium text-[15px]">Блог</a>
        <a href="/free-qr-generator.html" data-goal="qr_generator_link" data-goal-params='{"source":"nav"}' class="text-emerald-600 hover:text-emerald-700 transition font-bold text-[15px]">
          Бесплатный генератор
        </a>
      </div>

      <div class="hidden lg:flex items-center gap-3">
        <a href={APP_URL} data-goal="nav_login" class="text-slate-600 hover:text-primary transition font-medium text-[15px]">Войти</a>
        <a href={REGISTER_CTA_URL} data-goal={REGISTER_CTA_GOAL} target={isMenuLanding ? '_blank' : undefined} rel={isMenuLanding ? 'noopener noreferrer' : undefined} class="bg-primary text-white px-5 py-2 rounded-full font-semibold hover:bg-indigo-700 transition shadow-md shadow-indigo-500/20">
          {REGISTER_CTA_TEXT}
        </a>
      </div>

      <button
        id="nav-toggle"
        type="button"
        aria-label="Меню"
        class="lg:hidden w-10 h-10 flex items-center justify-center text-slate-700 rounded-lg hover:bg-slate-100 transition"
      >
        <i id="nav-icon" class="fa-solid fa-bars text-lg"></i>
      </button>
    </div>
  </div>

  <!-- Мобильное меню -->
  <div id="nav-mobile" class="hidden lg:hidden border-t border-slate-200 bg-white">
    <div class="px-4 py-4 space-y-4">
      <div>
        <div class="px-3 pb-2 text-xs font-bold uppercase tracking-wide text-slate-400">Продукты</div>
        <div class="space-y-1">
          {productLinks.map((link) => (
            <a href={link.href} class="block px-3 py-2.5 rounded-lg text-slate-700 font-medium hover:bg-slate-50 transition">{link.label}</a>
          ))}
        </div>
      </div>
      <div>
        <div class="px-3 pb-2 text-xs font-bold uppercase tracking-wide text-slate-400">Отрасли</div>
        <div class="space-y-1">
          {industryLinks.map((link) => (
            <a href={link.href} class="block px-3 py-2.5 rounded-lg text-slate-700 font-medium hover:bg-slate-50 transition">{link.label}</a>
          ))}
        </div>
      </div>
      <a href="/blog.html" class="block px-3 py-2.5 rounded-lg text-slate-700 font-medium hover:bg-slate-50 transition">Блог</a>
      <a href="/free-qr-generator.html" data-goal="qr_generator_link" data-goal-params='{"source":"nav_mobile"}' class="block px-3 py-2.5 rounded-lg text-emerald-600 font-bold hover:bg-emerald-50 transition">
        Бесплатный генератор QR
      </a>
      <div class="pt-3 mt-2 border-t border-slate-100 space-y-2">
        <a href={APP_URL} data-goal="nav_login" class="block text-center px-4 py-2.5 rounded-xl border border-slate-200 text-slate-700 font-semibold hover:bg-slate-50 transition">
          Войти
        </a>
        <a href={REGISTER_CTA_URL} data-goal={REGISTER_CTA_GOAL} target={isMenuLanding ? '_blank' : undefined} rel={isMenuLanding ? 'noopener noreferrer' : undefined} class="block text-center px-4 py-2.5 rounded-xl bg-primary text-white font-bold hover:bg-indigo-700 transition">
          {REGISTER_CTA_TEXT}
        </a>
      </div>
    </div>
  </div>
</nav>

<script is:inline>
  (function () {
    const toggle = document.getElementById('nav-toggle');
    const menu = document.getElementById('nav-mobile');
    const icon = document.getElementById('nav-icon');
    if (!toggle || !menu || !icon) return;
    toggle.addEventListener('click', function () {
      const open = menu.classList.toggle('hidden') === false;
      icon.className = open ? 'fa-solid fa-xmark text-lg' : 'fa-solid fa-bars text-lg';
    });
  })();
</script>
