---
// Yandex.Metrika counter — included site-wide via Layout.astro
---

<!-- Yandex.Metrika counter -->
<script is:inline>
  (function(m,e,t,r,i,k,a){
    m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
    m[i].l=1*new Date();
    for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
    k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
  })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=109307713', 'ym');

  ym(109307713, 'init', {ssr:true, webvisor:true, clickmap:true, ecommerce:"dataLayer", referrer: document.referrer, url: location.href, accurateTrackBounce:true, trackLinks:true});
</script>
<noscript><div><img src="https://mc.yandex.ru/watch/109307713" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
<!-- /Yandex.Metrika counter -->

<script is:inline>
  // Global helper: ym may not be ready yet, so queue if needed
  window.ymGoal = function(goal, params) {
    if (typeof ym === 'function') {
      ym(109307713, 'reachGoal', goal, params || {});
    }
  };

  // Page-load goals (e.g. qr_page_visit on /free-qr-generator.html)
  (function firePageGoals() {
    var pageGoals = {
      '/free-qr-generator.html': 'qr_page_visit',
    };
    var goal = pageGoals[location.pathname];
    if (!goal) return;
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() { window.ymGoal(goal); });
    } else {
      window.ymGoal(goal);
    }
  })();

  // Delegation: any element with data-goal fires a Metrica goal on click
  document.addEventListener('click', function(e) {
    var el = e.target && e.target.closest('[data-goal]');
    if (el) {
      var goal = el.getAttribute('data-goal');
      if (goal) {
        var rawParams = el.getAttribute('data-goal-params');
        var params = rawParams ? JSON.parse(rawParams) : undefined;
        window.ymGoal(goal, params);
      }
      return;
    }

    // Fallback: track clicks to the QR generator unless already tagged
    var link = e.target && e.target.closest('a[href*="free-qr-generator"]');
    if (link) window.ymGoal('qr_generator_link');
  }, true);

  // Intercept Ozon / Wildberries clicks
  document.addEventListener('click', function(e) {
    var link = e.target && e.target.closest('a');
    if (!link) return;
    
    var href = link.getAttribute('href') || '';
    if (href.indexOf('ozon.ru') !== -1 || href.indexOf('wildberries.ru') !== -1) {
      e.preventDefault();
      
      var platform = href.indexOf('ozon.ru') !== -1 ? 'ozon' : 'wildberries';
      
      // Trigger Yandex Metrika event
      if (typeof window.ymGoal === 'function') {
        window.ymGoal('table_order_attempt', { platform: platform });
      }
      
      // Create and show modal
      showMarketplaceModal();
    }
  }, true);

  function showMarketplaceModal() {
    if (document.getElementById('marketplace-modal')) return;
    
    var modal = document.createElement('div');
    modal.id = 'marketplace-modal';
    modal.className = 'fixed inset-0 z-[100] flex items-center justify-center p-4';
    
    var backdrop = document.createElement('div');
    backdrop.id = 'marketplace-modal-backdrop';
    backdrop.className = 'absolute inset-0 bg-slate-900/60 backdrop-blur-sm transition-opacity duration-300 opacity-0';
    
    var card = document.createElement('div');
    card.id = 'marketplace-modal-card';
    card.className = 'relative bg-white rounded-3xl p-6 sm:p-8 max-w-md w-full shadow-2xl border border-slate-100 transition-all duration-300 scale-95 opacity-0 transform z-10';
    
    card.innerHTML = '\
      <div class="flex flex-col items-center text-center">\
        <!-- Icon -->\
        <div class="w-16 h-16 bg-amber-50 text-amber-500 rounded-full flex items-center justify-center text-2xl mb-6 border border-amber-100">\
          <i class="fa-solid fa-hourglass-half animate-pulse"></i>\
        </div>\
        \
        <!-- Content -->\
        <h3 class="text-xl sm:text-2xl font-extrabold text-slate-900 mb-3">Таблички в разработке</h3>\
        <p class="text-slate-600 text-sm leading-relaxed mb-6">\
          Извините, готовые таблички пока находятся в разработке. Но вы можете скачать QR-код в личном кабинете и распечатать его самостоятельно — это абсолютно бесплатно!\
        </p>\
        \
        <!-- Buttons -->\
        <div class="flex flex-col sm:flex-row gap-3 w-full">\
          <button id="marketplace-modal-close" class="order-2 sm:order-1 flex-1 bg-slate-100 text-slate-700 py-3 rounded-xl font-bold text-sm hover:bg-slate-200 transition">\
            Ок, понятно\
          </button>\
          <a href="https://app.qrstars.ru" class="order-1 sm:order-2 flex-1 bg-primary text-white py-3 px-4 rounded-xl font-bold text-sm hover:bg-indigo-700 transition shadow-lg shadow-indigo-500/20 text-center flex items-center justify-center gap-1.5">\
            В кабинет <i class="fa-solid fa-arrow-right text-xs"></i>\
          </a>\
        </div>\
      </div>\
    ';
    
    modal.appendChild(backdrop);
    modal.appendChild(card);
    document.body.appendChild(modal);
    
    document.body.style.overflow = 'hidden';
    
    setTimeout(function() {
      backdrop.classList.remove('opacity-0');
      backdrop.classList.add('opacity-100');
      card.classList.remove('opacity-0', 'scale-95');
      card.classList.add('opacity-100', 'scale-100');
    }, 10);
    
    function closeModal() {
      backdrop.classList.remove('opacity-100');
      backdrop.classList.add('opacity-0');
      card.classList.remove('opacity-100', 'scale-100');
      card.classList.add('opacity-0', 'scale-95');
      
      setTimeout(function() {
        if (modal.parentNode) {
          modal.parentNode.removeChild(modal);
        }
        document.body.style.overflow = '';
      }, 300);
    }
    
    document.getElementById('marketplace-modal-close').addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);
  }
</script>
