---
// Yandex.Metrika counter — included site-wide via Layout.astro
---

<!-- Yandex.Metrika counter -->
<script is:inline>
  (function(m,e,t,r,i,k,a){
    m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
    m[i].l=1*new Date();
    for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
    k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
  })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=109307713', 'ym');

  ym(109307713, 'init', {ssr:true, webvisor:true, clickmap:true, ecommerce:"dataLayer", referrer: document.referrer, url: location.href, accurateTrackBounce:true, trackLinks:true});
</script>
<noscript><div><img src="https://mc.yandex.ru/watch/109307713" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
<!-- /Yandex.Metrika counter -->

<script is:inline>
  // Global helper: ym may not be ready yet, so queue if needed
  window.ymGoal = function(goal, params) {
    if (typeof ym === 'function') {
      ym(109307713, 'reachGoal', goal, params || {});
    }
  };

  // Page-load goals (e.g. qr_page_visit on /free-qr-generator.html)
  (function firePageGoals() {
    var pageGoals = {
      '/free-qr-generator.html': 'qr_page_visit',
    };
    var goal = pageGoals[location.pathname];
    if (!goal) return;
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() { window.ymGoal(goal); });
    } else {
      window.ymGoal(goal);
    }
  })();

  // Delegation: any element with data-goal fires a Metrica goal on click
  document.addEventListener('click', function(e) {
    var el = e.target && e.target.closest('[data-goal]');
    if (el) {
      var goal = el.getAttribute('data-goal');
      if (goal) {
        var rawParams = el.getAttribute('data-goal-params');
        var params = rawParams ? JSON.parse(rawParams) : undefined;
        window.ymGoal(goal, params);
      }
      return;
    }

    // Fallback: track clicks to the QR generator unless already tagged
    var link = e.target && e.target.closest('a[href*="free-qr-generator"]');
    if (link) window.ymGoal('qr_generator_link');
  }, true);

  // Pass _ym_uid and yclid to app.qrstars.ru
  document.addEventListener('click', function(e) {
    var a = e.target && e.target.closest('a[href*="app.qrstars.ru"]');
    if (!a) return;
    try {
      var url = new URL(a.href, location.origin);
      var m = document.cookie.match(/(?:^|;\s*)_ym_uid=([^;]+)/);
      if (m && m[1] && !url.searchParams.has('_ym_uid')) {
        url.searchParams.set('_ym_uid', decodeURIComponent(m[1]).trim());
      }
      var qs = new URLSearchParams(location.search);
      ['yclid', 'ymclid'].forEach(function(k) {
        var v = qs.get(k);
        if (v && !url.searchParams.has(k)) url.searchParams.set(k, v);
      });
      a.href = url.toString();
    } catch (_) {}
  }, true);
</script>
