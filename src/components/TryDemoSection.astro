---
import { generateBrandedQrDataUrl } from '../lib/brandedQr';

import { appendAttributionParams } from '../lib/utm';
const APP_BASE = appendAttributionParams('https://app.qrstars.ru', Astro.url.searchParams);

interface DemoScenario {
  name: string;
  path: string;
  badge: string;
  button: string;
  featured?: boolean;
  external?: boolean;
  showDisclaimer?: boolean;
}

const scenariosCoffee: DemoScenario[] = [
  {
    name: 'Микросайт (Всё в одном)',
    path: '/scan/demo-landing',
    badge: 'Главное демо · PRO · Рекомендуем',
    button: 'Открыть демо-микросайт',
    featured: true,
  },
  {
    name: 'Умные отзывы',
    path: '/scan/demo-review',
    badge: 'Хит · Рост рейтинга',
    button: 'Оценить заведение',
    showDisclaimer: true,
  },
  {
    name: 'Электронное QR-меню',
    path: '/scan/demo-menu',
    badge: 'PRO · С фото блюд',
    button: 'Изучить меню',
  },
  {
    name: 'Визитка сотрудника',
    path: '/scan/demo-business-card',
    badge: 'Контакты и чаевые',
    button: 'Сохранить контакт',
  },
  {
    name: 'Быстрый Wi-Fi',
    path: '/scan/demo-wifi',
    badge: 'Подключение за 1 клик',
    button: 'Подключиться к демо',
  },
  {
    name: 'Скачивание файла',
    path: '/scan/demo-file',
    badge: 'PDF-меню и инструкции',
    button: 'Скачать PDF-файл',
  },
  {
    name: 'Умный редирект',
    path: '/scan/demo-redirect',
    badge: 'Внешняя ссылка (Карты)',
    button: 'Перейти на Яндекс.Карты ↗',
    external: true,
  },
];

const scenariosTire: DemoScenario[] = [
  {
    name: 'Микросайт (Всё в одном)',
    path: '/scan/demo2-landing',
    badge: 'Главное демо · PRO · Рекомендуем',
    button: 'Открыть демо-микросайт',
    featured: true,
  },
  {
    name: 'Умные отзывы',
    path: '/scan/demo2-review',
    badge: 'Хит · Рост рейтинга',
    button: 'Оценить сервис',
    showDisclaimer: true,
  },
  {
    name: 'Прайс-лист услуг',
    path: '/scan/demo2-menu',
    badge: 'PRO · 15 услуг',
    button: 'Изучить прайс-лист',
  },
  {
    name: 'Визитка сотрудника',
    path: '/scan/demo2-business-card',
    badge: 'Контакты и чаевые',
    button: 'Сохранить контакт',
  },
  {
    name: 'Быстрый Wi-Fi',
    path: '/scan/demo2-wifi',
    badge: 'Подключение за 1 клик',
    button: 'Подключиться к демо',
  },
  {
    name: 'Скачивание файла',
    path: '/scan/demo2-file',
    badge: 'PDF-прайс и документы',
    button: 'Скачать PDF-файл',
  },
  {
    name: 'Умный редирект',
    path: '/scan/demo2-redirect',
    badge: 'Внешняя ссылка (Карты)',
    button: 'Перейти на Яндекс.Карты ↗',
    external: true,
  },
];

const scenariosClinic: DemoScenario[] = [
  {
    name: 'Микросайт (Всё в одном)',
    path: '/scan/demo3-landing',
    badge: 'Главное демо · PRO · Рекомендуем',
    button: 'Открыть демо-микросайт',
    featured: true,
  },
  {
    name: 'Умные отзывы',
    path: '/scan/demo3-review',
    badge: 'Хит · Рост рейтинга',
    button: 'Оценить приём',
    showDisclaimer: true,
  },
  {
    name: 'Прайс-лист услуг',
    path: '/scan/demo3-menu',
    badge: 'PRO · 15 услуг',
    button: 'Изучить прайс-лист',
  },
  {
    name: 'Визитка сотрудника',
    path: '/scan/demo3-business-card',
    badge: 'Контакты и запись',
    button: 'Сохранить контакт',
  },
  {
    name: 'Быстрый Wi-Fi',
    path: '/scan/demo3-wifi',
    badge: 'Подключение за 1 клик',
    button: 'Подключиться к демо',
  },
  {
    name: 'Скачивание файла',
    path: '/scan/demo3-file',
    badge: 'PDF-прейскурант',
    button: 'Скачать PDF-файл',
  },
  {
    name: 'Умный редирект',
    path: '/scan/demo3-redirect',
    badge: 'Внешняя ссылка (Карты)',
    button: 'Перейти на Яндекс.Карты ↗',
    external: true,
  },
];

interface Vertical {
  id: 'coffee' | 'tire' | 'clinic';
  icon: string;
  label: string;
  micrositePath: string;
  scenarios: DemoScenario[];
  accentRing: string;
  accentBadge: string;
  accentBtn: string;
  qrBadgeBg: string;
}

const verticals: Vertical[] = [
  {
    id: 'coffee',
    icon: 'fa-mug-hot',
    label: 'Кофейня',
    micrositePath: '/scan/demo-landing',
    scenarios: scenariosCoffee,
    accentRing: 'border-primary/30 ring-2 ring-primary/15',
    accentBadge: 'bg-primary/10 text-primary border-primary/20',
    accentBtn: 'bg-primary hover:bg-indigo-700 shadow-indigo-500/20',
    qrBadgeBg: 'bg-primary',
  },
  {
    id: 'tire',
    icon: 'fa-wrench',
    label: 'Шиномонтаж',
    micrositePath: '/scan/demo2-landing',
    scenarios: scenariosTire,
    accentRing: 'border-amber-400/30 ring-2 ring-amber-500/15',
    accentBadge: 'bg-amber-50 text-amber-700 border-amber-200',
    accentBtn: 'bg-amber-500 hover:bg-amber-600 shadow-amber-500/20',
    qrBadgeBg: 'bg-amber-500',
  },
  {
    id: 'clinic',
    icon: 'fa-tooth',
    label: 'Стоматология',
    micrositePath: '/scan/demo3-landing',
    scenarios: scenariosClinic,
    accentRing: 'border-sky-400/30 ring-2 ring-sky-500/15',
    accentBadge: 'bg-sky-50 text-sky-700 border-sky-200',
    accentBtn: 'bg-sky-500 hover:bg-sky-600 shadow-sky-500/20',
    qrBadgeBg: 'bg-sky-500',
  },
];

const allScenarios = verticals.flatMap((v) => v.scenarios);

const qrByPath = Object.fromEntries(
  await Promise.all(
    allScenarios.map(async (s) => {
      const url = `${APP_BASE}${s.path}`;
      const qr = await generateBrandedQrDataUrl(url, s.featured ? 200 : 140);
      return [s.path, { url, qr }] as const;
    }),
  ),
);
---

<section id="demo" class="py-20 lg:py-28 bg-gradient-to-b from-indigo-50/60 via-white to-white border-y border-indigo-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 lg:mb-16">
      <div class="inline-flex items-center gap-2 bg-primary/10 text-primary font-semibold px-4 py-1.5 rounded-full text-sm mb-5 border border-primary/20">
        <i class="fa-solid fa-mobile-screen-button"></i>
        Живые сценарии
      </div>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Попробуйте демо</h2>
      <p class="text-slate-600 max-w-2xl mx-auto leading-relaxed">
        Отсканируйте QR с экрана или взаимодействуйте с микросайтом прямо здесь — это реальное приложение, как у клиентов. Выберите отрасль, чтобы увидеть разницу.
      </p>

      <div class="flex justify-center mt-8 px-2">
        <div class="flex flex-wrap justify-center bg-slate-100 rounded-2xl p-1.5 gap-1 max-w-full">
          {verticals.map((v, i) => (
            <button
              type="button"
              data-demo-mode={v.id}
              data-goal="demo_vertical"
              class:list={['demo-mode-btn', i === 0 && 'active', 'relative flex items-center gap-2 px-3.5 sm:px-5 py-2.5 rounded-xl text-sm font-semibold transition-all']}
            >
              <i class:list={['fa-solid', v.icon, 'text-base']}></i>
              {v.label}
            </button>
          ))}
        </div>
      </div>
    </div>

    {verticals.map((v, vIdx) => {
      const micrositeUrl = `${APP_BASE}${v.micrositePath}`;
      return (
        <div data-demo-content={v.id} class:list={[vIdx !== 0 && 'hidden']}>
          <div class="flex flex-col items-center mb-16 lg:mb-20">
            <div
              class="phone-shell relative shrink-0 w-full max-w-[390px] aspect-[390/844] bg-slate-900 rounded-[2.75rem] shadow-2xl p-[10px] overflow-hidden"
            >
              <div class="absolute top-[10px] left-1/2 -translate-x-1/2 w-28 h-5 bg-slate-900 rounded-b-2xl z-10 pointer-events-none"></div>
              <div class="phone-screen relative w-full h-full bg-white overflow-hidden" style="border-radius: 2rem; clip-path: inset(0 round 2rem);">
                <iframe
                  data-demo-iframe={v.id}
                  data-src={micrositeUrl}
                  src={vIdx === 0 ? micrositeUrl : undefined}
                  title={`Демо: ${v.label}`}
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  sandbox="allow-scripts allow-same-origin allow-forms allow-popups allow-popups-to-escape-sandbox"
                  class="phone-iframe absolute top-0 left-0 border-0 bg-white"
                  style="width: 390px; height: 844px; transform-origin: top left; border-radius: 2.1rem;"
                ></iframe>
              </div>
            </div>
            <div class="flex items-center gap-3 mt-4 text-xs text-slate-500">
              <span class="font-medium">Живой микросайт · {APP_BASE.replace('https://', '')}{v.micrositePath}</span>
              <a
                href={micrositeUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 font-semibold text-primary hover:underline"
              >
                Открыть в новой вкладке <i class="fa-solid fa-arrow-up-right-from-square text-[10px]"></i>
              </a>
            </div>
          </div>

          <div class="flex flex-col lg:flex-row gap-6 lg:gap-8 items-start">
            <!-- Левая колонка: Вкладки -->
            <div class="w-full lg:w-1/3 flex flex-col gap-3 shrink-0">
              <div class="flex overflow-x-auto lg:flex-col gap-2 pb-4 lg:pb-0 scrollbar-hide snap-x snap-mandatory">
                {v.scenarios.map((scenario, sIdx) => (
                  <button
                    type="button"
                    data-scenario-tab={`${v.id}-${sIdx}`}
                    data-vertical={v.id}
                    data-accent-ring={v.accentRing}
                    aria-selected={sIdx === 0 ? "true" : "false"}
                    class:list={[
                      'scenario-tab-btn snap-start shrink-0 lg:shrink text-left px-5 py-4 rounded-2xl border transition-all w-[260px] lg:w-full',
                      sIdx === 0 
                        ? `bg-white shadow-md border-transparent ring-1 ring-slate-900/5 ${v.accentRing}` 
                        : 'bg-transparent border-slate-200 hover:bg-white hover:border-slate-300'
                    ]}
                  >
                    <div class="font-bold text-slate-900 text-sm sm:text-base mb-1">{scenario.name}</div>
                    <div class="text-xs text-slate-500 line-clamp-1">{scenario.badge}</div>
                  </button>
                ))}
              </div>
            </div>

            <!-- Правая колонка: Детали сценария -->
            <div class="w-full lg:w-2/3 bg-white rounded-3xl border border-slate-200 shadow-sm p-6 sm:p-8 lg:p-10 relative overflow-hidden">
              {v.scenarios.map((scenario, sIdx) => {
                const { url, qr } = qrByPath[scenario.path];
                return (
                  <div
                    data-scenario-content={`${v.id}-${sIdx}`}
                    class:list={[
                      'scenario-content flex-col md:flex-row gap-8 lg:gap-12 items-center',
                      sIdx === 0 ? 'flex' : 'hidden'
                    ]}
                  >
                    <div class="shrink-0 flex flex-col items-center">
                      <div class="relative inline-block p-3 bg-slate-50 rounded-2xl border border-slate-100 shadow-inner">
                        <img
                          src={qr}
                          width="180"
                          height="180"
                          alt={`QR: ${scenario.name}`}
                          class="rounded-xl block"
                          loading="lazy"
                        />
                        <div
                          class:list={[
                            'absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-10 h-10 rounded-xl flex items-center justify-center text-white font-extrabold text-[12px] shadow-lg ring-4 ring-white pointer-events-none',
                            v.qrBadgeBg,
                          ]}
                          aria-hidden="true"
                        >
                          QR
                        </div>
                      </div>
                      <p class="mt-3 text-[10px] font-bold uppercase tracking-widest text-slate-400">app.qrstars.ru</p>
                    </div>

                    <div class="flex-1 flex flex-col min-w-0 w-full text-center md:text-left">
                      <span
                        class:list={[
                          'inline-flex md:self-start self-center items-center font-bold rounded-full border mb-4 text-xs px-3 py-1',
                          scenario.featured ? v.accentBadge : 'bg-slate-100 text-slate-600 border-slate-200'
                        ]}
                      >
                        {scenario.badge}
                      </span>
                      <h3 class="font-bold text-2xl lg:text-3xl text-slate-900 mb-3 leading-tight">
                        {scenario.name}
                      </h3>

                      {scenario.external && (
                        <p class="text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded-lg px-3 py-2 mb-4 leading-relaxed text-left">
                          <i class="fa-solid fa-triangle-exclamation mr-1"></i>
                          После сканирования откроется внешняя ссылка (Яндекс.Карты), не страница QrStars.
                        </p>
                      )}

                      <a
                        href={url}
                        target="_blank"
                        rel="noopener noreferrer"
                        data-goal="demo_open"
                        class:list={[
                          'inline-flex items-center justify-center gap-2 rounded-xl font-bold transition mt-2 w-full md:w-auto text-base px-8 py-4 shadow-lg',
                          scenario.featured
                            ? `text-white ${v.accentBtn}`
                            : 'bg-slate-900 text-white hover:bg-slate-800'
                        ]}
                      >
                        {scenario.button}
                        {scenario.external && <span class="text-xs opacity-80" aria-hidden="true">↗</span>}
                      </a>

                      {scenario.showDisclaimer && (
                        <p class="text-[11px] text-slate-400 mt-4 leading-relaxed md:max-w-md">
                          * Демонстрационный режим: оценки и отзывы не сохраняются в базу данных и не отправляются в Telegram.
                        </p>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      );
    })}
  </div>
</section>

<style>
  .demo-mode-btn {
    color: rgb(100 116 139);
  }
  .demo-mode-btn.active {
    background: white;
    color: rgb(15 23 42);
    box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const modeBtns = document.querySelectorAll<HTMLButtonElement>('.demo-mode-btn');
    const contents = document.querySelectorAll<HTMLElement>('[data-demo-content]');
    const iframes = document.querySelectorAll<HTMLIFrameElement>('iframe[data-demo-iframe]');
    const screens = document.querySelectorAll<HTMLElement>('.phone-screen');

    const IFRAME_W = 390;
    const IFRAME_H = 844;

    function fitIframes() {
      screens.forEach((screen) => {
        const frame = screen.querySelector<HTMLIFrameElement>('.phone-iframe');
        if (!frame) return;
        const w = screen.clientWidth;
        if (!w) return;
        const scale = w / IFRAME_W;
        frame.style.transform = `scale(${scale})`;
        // Compensate iframe physical box so layout doesn't overflow
        frame.style.width = `${IFRAME_W}px`;
        frame.style.height = `${IFRAME_H}px`;
        screen.style.setProperty('--frame-scaled-h', `${IFRAME_H * scale}px`);
      });
    }

    function showMode(mode: string) {
      contents.forEach((el) => {
        el.classList.toggle('hidden', el.dataset.demoContent !== mode);
      });
      iframes.forEach((frame) => {
        if (frame.dataset.demoIframe === mode && !frame.src && frame.dataset.src) {
          frame.src = frame.dataset.src;
        }
      });
      // Newly-visible iframes need a refit (clientWidth is 0 when hidden)
      requestAnimationFrame(fitIframes);
    }

    modeBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const mode = btn.dataset.demoMode;
        modeBtns.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        if (mode) showMode(mode);
      });
    });

    const tabBtns = document.querySelectorAll<HTMLButtonElement>('.scenario-tab-btn');
    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const tabId = btn.dataset.scenarioTab;
        const verticalId = btn.dataset.vertical;
        if (!tabId || !verticalId) return;
        
        // Update Tabs
        document.querySelectorAll<HTMLButtonElement>(`.scenario-tab-btn[data-vertical="${verticalId}"]`).forEach(b => {
          const accentRing = b.dataset.accentRing || '';
          const ringClasses = accentRing.split(' ');
          
          if (b === btn) {
            b.setAttribute('aria-selected', 'true');
            b.classList.remove('bg-transparent', 'border-slate-200', 'hover:bg-white', 'hover:border-slate-300');
            b.classList.add('bg-white', 'shadow-md', 'border-transparent', 'ring-1', 'ring-slate-900/5', ...ringClasses);
            b.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
          } else {
            b.setAttribute('aria-selected', 'false');
            b.classList.add('bg-transparent', 'border-slate-200', 'hover:bg-white', 'hover:border-slate-300');
            b.classList.remove('bg-white', 'shadow-md', 'border-transparent', 'ring-1', 'ring-slate-900/5', ...ringClasses);
          }
        });

        // Update Contents
        document.querySelectorAll<HTMLElement>(`.scenario-content[data-scenario-content^="${verticalId}-"]`).forEach(c => {
          if (c.dataset.scenarioContent === tabId) {
            c.classList.remove('hidden');
            c.classList.add('flex');
          } else {
            c.classList.add('hidden');
            c.classList.remove('flex');
          }
        });
      });
    });

    fitIframes();
    window.addEventListener('resize', fitIframes);
  });
</script>
