---
import { LEGAL_LINKS } from '../lib/legal';

const seoLinks = [
  { href: '/qr-kod-dlya-otzyvov.html', label: 'QR для отзывов' },
  { href: '/generator-qr-kodov.html', label: 'Генератор QR' },
  { href: '/dinamicheskiy-qr-kod.html', label: 'Динамический QR' },
  { href: '/sozdat-qr-kod.html', label: 'Создать QR-код' },
];
---

<footer class="bg-white py-12 border-t border-slate-200 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-5 gap-8 mb-8">
      <div class="col-span-1 md:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center text-white font-bold">QR</div>
          <span class="font-bold text-xl tracking-tight">QrStars</span>
        </div>
        <p class="text-slate-500 text-sm max-w-sm mb-4">
          Умные QR-коды для локального бизнеса: отзывы на Яндекс Картах и 2GIS, меню, визитки, WiFi и аналитика.
        </p>
      </div>
      <div>
        <h4 class="font-bold text-slate-800 mb-4">Продукты</h4>
        <ul class="space-y-2 text-sm text-slate-500">
          <li><a href="/smart-reviews.html" class="hover:text-primary transition">Умные отзывы</a></li>
          <li><a href="/qr-business-cards.html" class="hover:text-primary transition">QR-визитки</a></li>
          <li><a href="/qr-menu.html" class="hover:text-primary transition">QR-меню</a></li>
          <li><a href="/file-sharing.html" class="hover:text-primary transition">QR-файлы</a></li>
          <li><a href="/#features" class="hover:text-primary transition">Конструктор QR</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-bold text-slate-800 mb-4">SEO-гайды</h4>
        <ul class="space-y-2 text-sm text-slate-500">
          {seoLinks.map((link) => (
            <li>
              <a href={link.href} class="hover:text-primary transition">{link.label}</a>
            </li>
          ))}
          <li><a href="/qr-kod-dlya-biznesa.html" class="hover:text-primary transition">QR для бизнеса</a></li>
          <li><a href="/qr-kod-s-logotipom.html" class="hover:text-primary transition">QR с логотипом</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-bold text-slate-800 mb-4">Платформа</h4>
        <ul class="space-y-2 text-sm text-slate-500">
          <li><a href="/blog.html" class="hover:text-primary transition">Блог</a></li>
          <li><a href="/#buy" class="hover:text-primary transition">Тарифы</a></li>
          <li><a href="#" class="hover:text-primary transition">Вход в кабинет</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-slate-100 pt-8 flex flex-col md:flex-row justify-between items-center text-slate-400 text-sm">
      <p>© 2026 QrStars.ru. Все права защищены.</p>
      <div class="flex gap-4 mt-4 md:mt-0">
        <a href={LEGAL_LINKS.privacy} class="hover:text-primary transition">Политика конфиденциальности</a>
        <a href={LEGAL_LINKS.consent} class="hover:text-primary transition">Согласие на передачу ПД</a>
      </div>
    </div>
  </div>
</footer>
