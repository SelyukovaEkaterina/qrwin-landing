---
interface Industry {
  icon: string;
  name: string;
}

interface Props {
  title?: string;
  industries: Industry[];
}

const { title = 'Для кого подходит', industries } = Astro.props;
---

<section class="py-16 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-center mb-10">{title}</h2>
    <div class="flex flex-wrap justify-center gap-4">
      {industries.map((item) => (
        <span class="inline-flex items-center gap-3 bg-white px-5 py-3 rounded-xl border border-slate-200 shadow-sm">
          <i class={`${item.icon} text-primary text-lg`}></i>
          <span class="font-medium text-slate-700">{item.name}</span>
        </span>
      ))}
    </div>
  </div>
</section>
