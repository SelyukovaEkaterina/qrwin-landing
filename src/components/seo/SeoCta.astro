---
interface Props {
  title?: string;
  text?: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  title = 'Создайте QR-код бесплатно за 30 секунд',
  text = 'Попробуйте QrStars — динамические QR-коды с логотипом, аналитикой и готовыми шаблонами для бизнеса.',
  ctaText = 'Создать QR-код',
  ctaHref = '/#features',
} = Astro.props;
---

<section class="py-16 lg:py-20 bg-gradient-to-br from-primary to-indigo-800 text-white">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-2xl md:text-3xl font-bold mb-4">{title}</h2>
    <p class="text-indigo-100 mb-8 text-lg">{text}</p>
    <a
      href={ctaHref}
      class="inline-flex items-center gap-2 bg-white text-primary px-8 py-4 rounded-xl font-bold text-lg hover:bg-slate-50 transition shadow-xl"
    >
      {ctaText}
      <i class="fa-solid fa-qrcode"></i>
    </a>
  </div>
</section>
