---
interface Props {
  badge?: string;
  h1: string;
  intro: string;
  ctaText?: string;
  ctaHref?: string;
  ctaSecondaryText?: string;
  ctaSecondaryHref?: string;
  ctaGoal?: string;
  ctaGoalParams?: string;
  ctaExternal?: boolean;
  ctaSecondaryGoal?: string;
  ctaSecondaryGoalParams?: string;
  ctaSecondaryExternal?: boolean;
}

const {
  badge,
  h1,
  intro,
  ctaText = 'Создать QR-код бесплатно',
  ctaHref = '/#features',
  ctaSecondaryText,
  ctaSecondaryHref,
  ctaGoal,
  ctaGoalParams,
  ctaExternal = false,
  ctaSecondaryGoal,
  ctaSecondaryGoalParams,
  ctaSecondaryExternal = false,
} = Astro.props;
---

<section class="pt-32 pb-16 lg:pt-40 lg:pb-20 overflow-hidden bg-slate-50 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="max-w-3xl">
      {badge && (
        <div class="inline-block bg-primary/10 text-primary font-semibold px-4 py-1.5 rounded-full text-sm mb-6 border border-primary/20">
          {badge}
        </div>
      )}
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight mb-6">
        {h1}
      </h1>
      <p class="text-lg md:text-xl text-slate-600 mb-8 leading-relaxed" set:html={intro} />
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href={ctaHref}
          {...(ctaGoal ? { 'data-goal': ctaGoal } : {})}
          {...(ctaGoalParams ? { 'data-goal-params': ctaGoalParams } : {})}
          target={ctaExternal ? '_blank' : undefined}
          rel={ctaExternal ? 'noopener noreferrer' : undefined}
          class="inline-flex items-center justify-center gap-2 bg-primary text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-indigo-700 transition shadow-lg shadow-indigo-500/30"
        >
          {ctaText}
          <i class="fa-solid fa-arrow-right"></i>
        </a>
        {ctaSecondaryText && ctaSecondaryHref && (
          <a
            href={ctaSecondaryHref}
            {...(ctaSecondaryGoal ? { 'data-goal': ctaSecondaryGoal } : {})}
            {...(ctaSecondaryGoalParams ? { 'data-goal-params': ctaSecondaryGoalParams } : {})}
            target={ctaSecondaryExternal ? '_blank' : undefined}
            rel={ctaSecondaryExternal ? 'noopener noreferrer' : undefined}
            class="inline-flex items-center justify-center gap-2 bg-white text-slate-800 border border-slate-200 px-8 py-4 rounded-xl font-bold text-lg hover:bg-slate-50 transition shadow-sm"
          >
            {ctaSecondaryText}
          </a>
        )}
      </div>
    </div>
  </div>
</section>
